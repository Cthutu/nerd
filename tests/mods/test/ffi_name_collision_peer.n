on "windows" {

    ffi "kernel32" {
        GetStdHandle (nStdHandle: u32) -> ^void
    }

    pub peer_os_value :: fn () -> ^void {
        return GetStdHandle(0xfffffff5)
    }

}

on "linux" {

    ffi "c" {
        getpid () -> i32
    }

    pub peer_os_value :: fn () -> i32 {
        return getpid()
    }

}
