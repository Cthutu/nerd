not_value :: fn(value: bool) -> bool {
    return !value
}

negative :: fn(value: i32) -> i32 {
    return -value
}

main :: fn() -> i32 {
    return 0
}
¬
hir 0
bind not_value = fn.0
bind negative = fn.1
bind main = fn.2
func fn.0(value: bool) -> bool {
  return bool logical_not(bool value)
}
func fn.1(value: i32) -> i32 {
  return i32 negate(i32 value)
}
func fn.2() -> i32 {
  return i32 0
}
