Point :: plex {
    x i32
    y i32
}

sum_point :: fn(point: Point) -> i32 {
    return point.x + point.y
}

main :: fn() -> i32 {
    point := Point { x: 1, y: 2 }
    moved := point with { y: 3 }
    return sum_point(moved)
}
¬
hir 0
bind Point = type.0
bind sum_point = fn.0
bind main = fn.1
type type.0 = Point
func fn.0(point: Point) -> i32 {
  return i32 add(i32 field(Point local.0(point), x), i32 field(Point local.0(point), y))
}
func fn.1() -> i32 {
  let point: Point = Point plex(x: i32 1, y: i32 2)
  let moved: Point = Point plex_update(Point local.1(point), y: i32 3)
  return i32 call bind.1(sum_point)(Point local.2(moved))
}
