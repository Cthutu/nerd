func sum_point(point: Point) -> i32 {
  return i32 add(i32 field(Point point, x), i32 field(Point point, y))
}
func main() -> i32 {
  let point: Point = Point plex(x: i32 1, y: i32 2)
  let moved: Point = Point plex_update(Point point, y: i32 3)
  return i32 call sum_point(Point moved)
}
