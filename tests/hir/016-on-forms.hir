Point :: plex {
    x i32
    y i32
}

Choice :: enum {
    Empty
    Value(i32)
    Pair(i32, i32)
}

classify :: fn(value: i32) -> i32 {
    return on value {
        0 => 10
        1..3 as matched on matched == 2 => matched + 20
        else as other => other + 100
    }
}

score :: fn(point: Point) -> i32 {
    return on point {
        { x: 0, y: as y } => y
        { x: as x, y: 9 } => x * 10
        else => 0
    }
}

first_positive :: fn(value: i32) -> i32 {
    on value > 0 => return value
    return 0
}

describe_choice :: fn(choice: Choice) -> i32 {
    return on choice {
        Empty() => 0
        Value(as value) => value
        Pair(as left, 4) => left
        else => 99
    }
}

compare_pattern :: fn(value: i32) -> i32 {
    return on value {
        == 0 => 1
        != 1 => 2
        < 4 => 3
        <= 5 => 4
        > 6 => 5
        >= 7 => 6
        else => 7
    }
}

main :: fn() -> i32 {
    point := Point { x: 4, y: 9 }
    return on {
        classify(2) == 22 => score(point)
        else => 0
    }
}
¬
hir 0
bind Point = type.0
bind Choice = type.1
bind classify = fn.0
bind score = fn.1
bind first_positive = fn.2
bind describe_choice = fn.3
bind compare_pattern = fn.4
bind main = fn.5
type type.0 = Point
type type.1 = Choice
func fn.0(value: i32) -> i32 {
  return i32 on i32 local.0(value) {
    value(i32 0) => {
      expr i32 10
    }
    range_exclusive(i32 1, i32 3) as matched when bool equal(i32 local.1(matched), i32 2) => {
      expr i32 add(i32 local.1(matched), i32 20)
    }
    else as other => {
      expr i32 add(i32 local.2(other), i32 100)
    }
  }
}
func fn.1(point: Point) -> i32 {
  return i32 on Point local.3(point) {
    plex(x: value(i32 0), y: as y) => {
      expr i32 local.4(y)
    }
    plex(x: as x, y: value(i32 9)) => {
      expr i32 multiply(i32 local.5(x), i32 10)
    }
    else => {
      expr i32 0
    }
  }
}
func fn.2(value: i32) -> i32 {
  expr void on bool greater(i32 local.6(value), i32 0) {
    value(bool yes) => {
      return i32 local.6(value)
    }
  }
  return i32 0
}
func fn.3(choice: Choice) -> i32 {
  return i32 on Choice local.7(choice) {
    enum_variant(Empty) => {
      expr i32 0
    }
    enum_variant(Value, as value) => {
      expr i32 local.8(value)
    }
    enum_variant(Pair, as left, value(i32 4)) => {
      expr i32 local.9(left)
    }
    else => {
      expr i32 99
    }
  }
}
func fn.4(value: i32) -> i32 {
  return i32 on i32 local.10(value) {
    equal(i32 0) => {
      expr i32 1
    }
    not_equal(i32 1) => {
      expr i32 2
    }
    less(i32 4) => {
      expr i32 3
    }
    less_equal(i32 5) => {
      expr i32 4
    }
    greater(i32 6) => {
      expr i32 5
    }
    greater_equal(i32 7) => {
      expr i32 6
    }
    else => {
      expr i32 7
    }
  }
}
func fn.5() -> i32 {
  let point: Point = Point plex(x: i32 4, y: i32 9)
  return i32 on condition {
    bool equal(i32 call bind.2(classify)(i32 2), i32 22) => {
      expr i32 call bind.3(score)(Point local.11(point))
    }
    else => {
      expr i32 0
    }
  }
