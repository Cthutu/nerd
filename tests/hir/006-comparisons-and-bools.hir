is_less :: fn(a: i32, b: i32) -> bool {
    return a < b
}

is_ready :: fn(a: bool, b: bool) -> bool {
    return a && b || yes
}

main :: fn() -> i32 {
    return 0
}
¬
hir 0
bind is_less = fn.0
bind is_ready = fn.1
bind main = fn.2
func fn.0(a: i32, b: i32) -> bool {
  return bool less(i32 local.0(a), i32 local.1(b))
}
func fn.1(a: bool, b: bool) -> bool {
  return bool logical_or(bool logical_and(bool local.2(a), bool local.3(b)), bool yes)
}
func fn.2() -> i32 {
  return i32 0
}
