sum_while :: fn(limit: i32) -> i32 {
    total := 0
    i := 0
    for i < limit {
        total += i
        i += 1
    }
    return total
}

sum_c_style :: fn() -> i32 {
    total := 0
    for i := 0; i < 3; i += 1 {
        total += i
    }
    return total
}

sum_for_in :: fn(values: []i32) -> i32 {
    total := 0
    for index, value in values {
        total += value^ + index.as(i32)
    }
    return total
}

increment_first :: fn(values: []i32) -> i32 {
    for value in values {
        value^ += 1
        break
    }
    return values[0]
}

with_else :: fn(limit: i32) -> i32 {
    return for i := 0; i < limit; i += 1 {
        break i
    } else {
        break -1
    }
}

labelled_value :: fn() -> i32 {
    return for $loop {
        break $loop 42
    }
}

main :: fn() -> i32 {
    values := [1, 2, 3]
    return sum_while(3) + sum_c_style() + sum_for_in(values[..]) +
        increment_first(values[..]) + with_else(0) + labelled_value()
}
