--

use std.collections
use std.io
use std.random
use std.term

main :: fn () {
    random_number := random_u64()
    prn($"Random number: {random_number}")

    stack : Stack[i32]

    stack.push(42)
    stack.push(13)

    prn($"Popped: {stack.pop()}")
    prn($"Popped: {stack.pop()}")
}

test "Basic" {
    assert 1 + 1 == 2, "Simple check"
    -- assert 1 + 0 == 2, "Simple fail"
}
