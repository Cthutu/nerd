{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run adventure",
            "type": "process",
            "command": "nerd",
            "args": [
                "run",
                "quill.n"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": "$gcc"
        },
    ]
}
