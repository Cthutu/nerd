{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Dungeon (Nerd + CodeLLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/_tmp/debug/dungeon",
            "args": [],
            "cwd": "${workspaceFolder}/examples/dungeon",
            "env": {
                "NERD_LIB_PATH": "${workspaceFolder}/mods"
            },
            "preLaunchTask": "Build Dungeon Debug",
            "terminal": "integrated",
            "sourceLanguages": [
                "c"
            ]
        },
        {
            "name": "Launch Executable (Linux)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/_bin/nerd-debug",
            "args": [
                "run",
                "examples/text-adventure/adv.n"
            ],
            "env": {
                "NERD_LIB_PATH": "c:\\users\\matt\\nerd\\mods"
            },
            "cwd": "${workspaceFolder}",
            // "preLaunchTask": "Compile"
        },
    ]
}
