{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile",
            "type": "process",
            "command": "just",
            "args": [
                "run-example"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Dungeon Debug",
            "type": "shell",
            "command": "mkdir -p \"${workspaceFolder}/_tmp/debug\" && \"${workspaceFolder}/_bin/nerd-debug\" build --output \"${workspaceFolder}/_tmp/debug/dungeon\" \"${workspaceFolder}/examples/dungeon/dungeon.n\"",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "NERD_LIB_PATH": "${workspaceFolder}/mods"
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build Debugger Fixture",
            "type": "shell",
            "command": "mkdir -p \"${workspaceFolder}/_tmp/debug\" && \"${workspaceFolder}/_bin/nerd-debug\" build --output \"${workspaceFolder}/_tmp/debug/debug\" \"${workspaceFolder}/examples/debug/debug.n\"",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "NERD_LIB_PATH": "${workspaceFolder}/mods"
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Compile-Release",
            "type": "process",
            "command": "just",
            "args": [
                "build-release"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}
