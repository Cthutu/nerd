test "png decodes embedded 2x2 RGB fixture to RGBA" {
    bytes: [77]u8 = [
        137,
        80,
        78,
        71,
        13,
        10,
        26,
        10,
        0,
        0,
        0,
        13,
        73,
        72,
        68,
        82,
        0,
        0,
        0,
        2,
        0,
        0,
        0,
        2,
        8,
        2,
        0,
        0,
        0,
        253,
        212,
        154,
        115,
        0,
        0,
        0,
        20,
        73,
        68,
        65,
        84,
        120,
        156,
        99,
        248,
        207,
        192,
        192,
        0,
        194,
        12,
        255,
        255,
        255,
        255,
        15,
        0,
        31,
        238,
        5,
        251,
        176,
        184,
        151,
        201,
        0,
        0,
        0,
        0,
        73,
        69,
        78,
        68,
        174,
        66,
        96,
        130,
    ]

    rgb_result := Image.load_bytes(bytes[..])

    on rgb_result {
        Ok(image) => {
            assert image.width == 2
            assert image.height == 2
            assert image.channels == 3
            assert image.data.count == 12
            assert image.data[0] == 255
            assert image.data[1] == 0
            assert image.data[2] == 0
            assert image.data[3] == 0
            assert image.data[4] == 255
            assert image.data[5] == 0
            assert image.data[6] == 0
            assert image.data[7] == 0
            assert image.data[8] == 255
            assert image.data[9] == 255
            assert image.data[10] == 255
            assert image.data[11] == 255
            image.free()
        }
        else => {
            assert no
        }
    }

    rgb3_result := Image.load_bytes(bytes[..], 3)

    on rgb3_result {
        Ok(image) => {
            assert image.channels == 3
            assert image.data.count == 12
            image.free()
        }
        else => {
            assert no
        }
    }

    rgba_result := Image.load_bytes(bytes[..], 4)

    on rgba_result {
        Ok(image) => {
            assert image.width == 2
            assert image.height == 2
            assert image.channels == 4
            assert image.data.count == 16
            assert image.data[0] == 255
            assert image.data[1] == 0
            assert image.data[2] == 0
            assert image.data[3] == 255
            assert image.data[4] == 0
            assert image.data[5] == 255
            assert image.data[6] == 0
            assert image.data[7] == 255
            assert image.data[8] == 0
            assert image.data[9] == 0
            assert image.data[10] == 255
            assert image.data[11] == 255
            assert image.data[12] == 255
            assert image.data[13] == 255
            assert image.data[14] == 255
            assert image.data[15] == 255
            image.free()
        }
        else => {
            assert no
        }
    }
}

