            assert image.data[1] == 20
            assert image.data[2] == 30
            assert image.data[3] == 200
            assert image.data[4] == 210
            assert image.data[5] == 220
            image.free()
        }
        else => {
            assert no
        }
    }

    transparent_result := Image.load_bytes(transparent_bytes[..])
    on transparent_result {
        image => {
            assert image.channels == 4
            assert image.data[0] == 10
            assert image.data[1] == 20
            assert image.data[2] == 30
            assert image.data[3] == 0
            assert image.data[4] == 200
            assert image.data[5] == 210
            assert image.data[6] == 220
            assert image.data[7] == 255
            image.free()
        }
        else => {
            assert no
        }
    }
}

test "png converts to desired greyscale channels" {
    bytes: [77]u8 = [
        137,
        80,
        78,
        71,
        13,
        10,
        26,
        10,
        0,
        0,
        0,
        13,
        73,
        72,
        68,
        82,
        0,
        0,
        0,
        2,
        0,
        0,
        0,
        2,
        8,
        2,
        0,
        0,
        0,
        253,
        212,
        154,
        115,
        0,
        0,
        0,
        20,
        73,
        68,
        65,
        84,
        120,
        156,
        99,
        248,
        207,
        192,
        192,
        0,
        194,
        12,
        255,
        255,
        255,
        255,
        15,
        0,
        31,
        238,
        5,
        251,
        176,
        184,
        151,
        201,
        0,
        0,
        0,
        0,
        73,
        69,
        78,
        68,
        174,
        66,
        96,
        130,
    ]

    grey_result := Image.load_bytes(bytes[..], 1)
    on grey_result {
        image => {
            assert image.channels == 1
            assert image.data.count == 4
            assert image.data[0] == 76
            assert image.data[1] == 149
            assert image.data[2] == 28
            assert image.data[3] == 255
            image.free()
        }
        else => {
            assert no
        }
    }

    grey_alpha_result := Image.load_bytes(bytes[..], 2)
    on grey_alpha_result {
        image => {
            assert image.channels == 2
            assert image.data.count == 8
            assert image.data[0] == 76
            assert image.data[1] == 255
            assert image.data[2] == 149
            assert image.data[3] == 255
            image.free()
        }
        else => {
            assert no
        }
    }
}

