            png.free()
        }
        else => {
        }
    }
}

test "png reads IHDR chunk" {
    bytes: [25]u8 = [
        0,
        0,
        0,
        13,
        'I',
        'H',
        'D',
        'R',
        0,
        0,
        0,
        2,
        0,
        0,
        0,
        3,
        8,
        2,
        0,
        0,
        0,
        0x36,
        0x88,
        0x49,
        0xd6,
    ]
    reader := ImageReader.new(bytes[..])

    chunk := png_read_chunk(^reader)

    on chunk {
        value => {
            assert value.length == 13
            assert value.kind == PNG_CHUNK_IHDR
            assert value.data.count == 13
            assert value.crc == 914901462.as(u32)
        }
        else => {
            assert no
        }
    }
}

test "png computes chunk CRC" {
    ihdr: [13]u8 = [
        0,
        0,
        0,
        2,
        0,
        0,
        0,
        3,
        8,
        2,
        0,
        0,
        0,
    ]
    empty : [0]u8 = []

    assert png_chunk_crc(PNG_CHUNK_IHDR, ihdr[..]) == 914901462.as(u32)
    assert png_chunk_crc(PNG_CHUNK_IDAT, empty[..]) == 900662814.as(u32)
    assert png_chunk_crc(PNG_CHUNK_IEND, empty[..]) == 2923585666.as(u32)
}

