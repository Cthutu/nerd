test "png rejects missing IEND" {
    bytes: [33]u8 = [
        0x89,
        'P',
        'N',
        'G',
        13,
        10,
        26,
        10,
        0,
        0,
        0,
        13,
        'I',
        'H',
        'D',
        'R',
        0,
        0,
        0,
        1,
        0,
        0,
        0,
        1,
        8,
        2,
        0,
        0,
        0,
        0x90,
        0x77,
        0x53,
        0xde,
    ]

    parsed := png_parse(bytes[..])

    on parsed {
        UnexpectedEnd! => {
        }
        else => {
            assert no
        }
    }
}

