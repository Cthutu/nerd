-- Nerd Standard Library (NSL)
--
-- Copyright (c) 2026 Matt Davies
--
-- Parses PNG container structure and decodes non-interlaced 8-bit RGB/RGBA
-- image data.

use std.compress

PNG_SIGNATURE_SIZE :: 8

PNG_CHUNK_IHDR ::
                  ('I'.as(u32) << 24) | ('H'.as(u32) << 16) | ('D'.as(u32) << 8) | 'R'.as(u32)
PNG_CHUNK_IDAT ::
                  ('I'.as(u32) << 24) | ('D'.as(u32) << 16) | ('A'.as(u32) << 8) | 'T'.as(u32)
PNG_CHUNK_IEND ::
                  ('I'.as(u32) << 24) | ('E'.as(u32) << 16) | ('N'.as(u32) << 8) | 'D'.as(u32)

PngChunk :: plex {
    length u32
    kind   u32
    data   []u8
    crc    u32
}

PngIhdr :: plex {
    width       u32
    height      u32
    bit_depth   u8
    color_type  u8
    compression u8
    filter      u8
    interlace   u8
}

PngContainer :: plex {
    ihdr        PngIhdr
    idat_chunks [..][]u8
}

impl PngContainer {

    free :: fn (png: ^Self) {
        png.idat_chunks.free()
    }

}

png_invalid :: fn (message: string) -> Result[PngContainer, ImageError] {
    return Err(ImageError.InvalidData { message })
}

png_error :: fn (error: ImageError) -> Result[PngContainer, ImageError] {
    return Err(error)
}

png_ok :: fn (png: PngContainer) -> Result[PngContainer, ImageError] {
    return Ok(png)
}

png_image_invalid :: fn (message: string) -> Result[Image, ImageError] {
    return Err(ImageError.InvalidData { message })
}

png_image_error :: fn (error: ImageError) -> Result[Image, ImageError] {
    return Err(error)
}

png_image_ok :: fn (image: Image) -> Result[Image, ImageError] {
    return Ok(image)
}

png_invalid_chunk :: fn (message: string) -> Result[PngChunk, ImageError] {
    return Err(ImageError.InvalidData { message })
}

png_chunk_error :: fn (error: ImageError) -> Result[PngChunk, ImageError] {
    return Err(error)
}

png_signature_matches :: fn (signature: []u8) -> bool {
    return signature.count == PNG_SIGNATURE_SIZE && signature[0] == 0x89 && signature[1] == 'P' && signature[2] == 'N' && signature[3] == 'G' && signature[4] == 13 && signature[5] == 10 && signature[6] == 26 && signature[7] == 10
}

png_chunk_kind_byte :: fn (kind: u32, index: i32) -> u8 {
    return on index {
        0     => ((kind >> 24) & 0xff).as(u8)
        1     => ((kind >> 16) & 0xff).as(u8)
        2     => ((kind >> 8) & 0xff).as(u8)
        else  => (kind & 0xff).as(u8)
    }
}

png_crc32_update :: fn (crc: u32, byte: u8) -> u32 {
    next := crc ^ byte.as(u32)

    for _ in [0 .. 8] {
        next = on (next & 1) == 1 => ((next >> 1) ^ 0xedb88320.as(u32)) else next >> 1
    }

    return next
}

png_chunk_crc :: fn (kind: u32, data: []u8) -> u32 {
    crc := 0xffffffff.as(u32)

    for index in [0 .. 4] {
        crc = png_crc32_update(crc, png_chunk_kind_byte(kind, index))
    }

    for byte in data {
        crc = png_crc32_update(crc, byte^)
    }

    return ~crc
}

png_be_u32_at :: fn (bytes: []u8, index: usize) -> u32 {
    return (bytes[index].as(u32) << 24) | (bytes[index + 1].as(u32) << 16) | (bytes[index + 2].as(u32) << 8) | bytes[index + 3].as(u32)
}

png_parse_ihdr :: fn (chunk: PngChunk) -> PngIhdr {
    return {
        width       : png_be_u32_at(chunk.data, 0)
        height      : png_be_u32_at(chunk.data, 4)
        bit_depth   : chunk.data[8]
        color_type  : chunk.data[9]
        compression : chunk.data[10]
        filter      : chunk.data[11]
        interlace   : chunk.data[12]
    }
}

png_read_chunk :: fn (reader: ^ImageReader) -> Result[PngChunk, ImageError] {
    on reader.remaining() < 8 => return png_chunk_error(UnexpectedEnd)

    chunk_length := png_be_u32_at(reader.bytes, reader.offset)
    reader.offset += 4

    chunk_kind := png_be_u32_at(reader.bytes, reader.offset)
    reader.offset += 4

    on reader.remaining() < chunk_length.as(usize) + 4 => return png_chunk_error(UnexpectedEnd)

    data_start := reader.offset
    data_end := data_start + chunk_length.as(usize)
    chunk_data := reader.bytes[data_start..data_end]
    reader.offset = data_end

    chunk_crc := png_be_u32_at(reader.bytes, reader.offset)
    reader.offset += 4

    on (png_chunk_crc(chunk_kind, chunk_data) != chunk_crc) => {
        return png_invalid_chunk("PNG chunk CRC mismatch")
    }

    return Ok({
        length : chunk_length
        kind   : chunk_kind
        data   : chunk_data
        crc    : chunk_crc
    })
}

png_parse :: fn (bytes: []u8) -> Result[PngContainer, ImageError] {
    on !image_is_png(bytes) => return png_error(UnsupportedFormat)

    reader := ImageReader.new(bytes)
    signature := reader.take(PNG_SIGNATURE_SIZE)
    on signature {
        Err(error) => return png_error(error)
        Ok(value) => {
            on !png_signature_matches(value) => return png_error(UnsupportedFormat)
        }
    }

    ihdr := PngIhdr {
        width       : 0
        height      : 0
        bit_depth   : 0
        color_type  : 0
        compression : 0
        filter      : 0
        interlace   : 0
    }
    idat_chunks : [..][]u8 = nil
    seen_ihdr := no
    seen_idat := no

    for !reader.done() {
        chunk : Result[PngChunk, ImageError] = png_read_chunk(^reader)
        on chunk {
            Ok(value) => {
                on (value.kind == PNG_CHUNK_IHDR) => {
                    on seen_ihdr => {
                        idat_chunks.free()
                        return png_invalid("PNG contains more than one IHDR chunk")
                    }
                    on seen_idat => {
                        idat_chunks.free()
                        return png_invalid("PNG IHDR chunk must appear before IDAT")
                    }

                    on (value.length != 13) => {
                        idat_chunks.free()
                        return png_invalid("PNG IHDR chunk must be 13 bytes")
                    }
                    header := png_parse_ihdr(value)

                    on header.width == 0 ||
                        header.height == 0 => {
                        idat_chunks.free()
                        return png_invalid("PNG IHDR width and height must be nonzero")
                    }
                    ihdr.width = header.width
                    ihdr.height = header.height
                    ihdr.bit_depth = header.bit_depth
                    ihdr.color_type = header.color_type
                    ihdr.compression = header.compression
                    ihdr.filter = header.filter
                    ihdr.interlace = header.interlace
                    seen_ihdr = yes
                }
                on (value.kind == PNG_CHUNK_IDAT) => {
                    on !seen_ihdr => {
                        idat_chunks.free()
                        return png_invalid("PNG IDAT chunk appeared before IHDR")
                    }
                    idat_chunks.push(value.data)
                    seen_idat = yes
                }
                on (value.kind == PNG_CHUNK_IEND) => {
                    on (value.length != 0) => {
                        idat_chunks.free()
                        return png_invalid("PNG IEND chunk must be empty")
                    }
                    on !seen_ihdr => {
                        idat_chunks.free()
                        return png_invalid("PNG ended before IHDR")
                    }
                    on !seen_idat => {
                        idat_chunks.free()
                        return png_invalid("PNG ended before IDAT")
                    }
                    return png_ok({
                        ihdr
                        idat_chunks
                    })
                }
                again
            }
            Err(error) => {
                idat_chunks.free()
                return png_error(error)
            }
        }
    }

    idat_chunks.free()
    return Err(UnexpectedEnd)
}

png_source_channels :: fn (color_type: u8) -> Result[i32, ImageError] {
    return on color_type {
        2     => Ok(3)
        6     => Ok(4)
        else  => Err(UnsupportedFormat)
    }
}

png_desired_channels :: fn (source_channels  : i32,
                            desired_channels : i32) -> Result[i32, ImageError] {
    on desired_channels == 0 => return Ok(source_channels)
    on desired_channels == 3 ||
        desired_channels == 4 => return Ok(desired_channels)
    return Err(UnsupportedFormat)
}

png_validate_ihdr_for_decode :: fn (ihdr: PngIhdr) -> Result[i32, ImageError] {
    on ihdr.bit_depth != 8 => return Err(UnsupportedFormat)
    on ihdr.compression != 0 ||
        ihdr.filter != 0 ||
        ihdr.interlace != 0 => return Err(ImageError.InvalidData {
        message: "Unsupported PNG encoding"
    })
    return png_source_channels(ihdr.color_type)
}

png_idat_bytes :: fn (png: ^PngContainer) -> [..]u8 {
    bytes : [..]u8 = nil

    for chunk in png.idat_chunks {
        for byte in chunk^ {
            bytes.push(byte^)
        }
    }

    return bytes
}

png_paeth :: fn (left: u8, up: u8, upper_left: u8) -> u8 {
    p := left.as(i32) + up.as(i32) - upper_left.as(i32)
    pa := p - left.as(i32)
    pb := p - up.as(i32)
    pc := p - upper_left.as(i32)

    on pa < 0 => pa = -pa
    on pb < 0 => pb = -pb
    on pc < 0 => pc = -pc

    on pa <= pb && pa <= pc => return left
    on pb <= pc => return up
    return upper_left
}

png_unfilter_byte :: fn (filter     : u8,
                         encoded    : u8,
                         left       : u8,
                         up         : u8,
                         upper_left : u8) -> u8 {
    on filter == 0 => return encoded
    on filter == 1 => return (encoded.as(u16) + left.as(u16)).as(u8)
    on filter == 2 => return (encoded.as(u16) + up.as(u16)).as(u8)
    on filter == 3 => return (encoded.as(u16) + ((left.as(u16) + up.as(u16)) / 2)).as(u8)
    return (encoded.as(u16) + png_paeth(left, up, upper_left).as(u16)).as(u8)
}

png_unfilter :: fn (bytes           : []u8,
                    width           : u32,
                    height          : u32,
                    source_channels : i32) -> Result[[..]u8, ImageError] {
    row_bytes := width.as(usize) * source_channels.as(usize)
    expected_bytes := height.as(usize) * (row_bytes + 1)

    on bytes.count != expected_bytes => return Err(ImageError.InvalidData { message: "PNG decompressed data has unexpected size" })

    pixels : [..]u8 = nil

    for y in [0 .. height.as(usize)] {
        scanline_start := y * (row_bytes + 1)
        row_start := scanline_start + 1
        row_end := row_start + row_bytes
        filter := bytes[scanline_start]
        row := bytes[row_start..row_end]

        on filter > 4 => {
            pixels.free()
            return Err(ImageError.InvalidData { message: "Invalid PNG scanline filter" })
        }
        for x in [0 .. row_bytes] {
            left := on x >= source_channels.as(usize) => pixels[y * row_bytes + x - source_channels.as(usize)] else 0
            up := on y > 0 => pixels[(y - 1) * row_bytes + x] else 0
            upper_left := on y > 0 && x >= source_channels.as(usize) => pixels[(y - 1) * row_bytes + x - source_channels.as(usize)] else 0

            pixels.push(png_unfilter_byte(filter, row[x], left, up, upper_left))
        }
    }

    return Ok(pixels)
}

png_convert_channels :: fn (pixels           : []u8,
                            width            : u32,
                            height           : u32,
                            source_channels  : i32,
                            desired_channels : i32) -> Result[[..]u8, ImageError] {
    on source_channels == desired_channels => {
        output : [..]u8 = nil
        output.resize_undefined_to(pixels.count)
        for i in [0 .. pixels.count] {
            output[i] = pixels[i]
        }
        return Ok(output)
    }

    count := width.as(usize) * height.as(usize)
    output : [..]u8 = nil
    output.resize_undefined_to(count * desired_channels.as(usize))

    for pixel in [0 .. count] {
        source := pixel * source_channels.as(usize)
        target := pixel * desired_channels.as(usize)

        output[target] = pixels[source]
        output[target + 1] = pixels[source + 1]
        output[target + 2] = pixels[source + 2]

        on desired_channels == 4 => {
            output[target + 3] = on source_channels == 4 => pixels[source + 3] else 255
        }
    }

    return Ok(output)
}

png_decode :: fn (bytes            : []u8,
                  desired_channels : i32 = 0) -> Result[Image, ImageError] {
    parsed := png_parse(bytes)

    on parsed {
        Err(error) => return png_image_error(error)
        Ok(png) => {
            source_channels := png_validate_ihdr_for_decode(png.ihdr)
            on source_channels {
                Err(error) => {
                    png.free()
                    return png_image_error(error)
                }
                Ok(channels) => {
                    output_channels := png_desired_channels(channels,
                                                            desired_channels)
                    on output_channels {
                        Err(error) => {
                            png.free()
                            return png_image_error(error)
                        }
                        Ok(final_channels) => {
                            compressed := png_idat_bytes(^png)
                            png.free()
                            defer compressed.free()

                            row_bytes := png.ihdr.width.as(usize) * channels.as(usize)
                            expected_bytes := png.ihdr.height.as(usize) * (row_bytes + 1)
                            decompressed := compressed[..].deflate_zlib(expected_bytes)
                            on decompressed {
                                Err(error) => {
                                    return on error {
                                        CompressionError.UnsupportedFormat        => png_image_error(UnsupportedFormat)
                                        CompressionError.UnexpectedEnd            => png_image_error(UnexpectedEnd)
                                        CompressionError.OutputLimitExceeded      => png_image_invalid("PNG decompressed data exceeded expected size")
                                        CompressionError.InvalidData { message }  => png_image_invalid(message)
                                    }
                                }
                                Ok(scanlines) => {
                                    unfiltered := png_unfilter(scanlines[..],
                                                               png.ihdr.width,
                                                               png.ihdr.height,
                                                               channels)
                                    scanlines.free()
                                    on unfiltered {
                                        Err(error) => {
                                            return png_image_error(error)
                                        }
                                        Ok(raw_pixels) => {
                                            converted := png_convert_channels(raw_pixels[..],
                                                                              png.ihdr.width,
                                                                              png.ihdr.height,
                                                                              channels,
                                                                              final_channels)
                                            raw_pixels.free()
                                            on converted {
                                                Err(error) => {
                                                    return png_image_error(error)
                                                }
                                                Ok(data) => {
                                                    return png_image_ok({
                                                        width    : png.ihdr.width.as(i32)
                                                        height   : png.ihdr.height.as(i32)
                                                        channels : final_channels
                                                        data
                                                    })
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

test "png parses valid IHDR IDAT and IEND" {
    bytes: [57]u8 = [
        0x89,
        'P',
        'N',
        'G',
        13,
        10,
        26,
        10,
        0,
        0,
        0,
        13,
        'I',
        'H',
        'D',
        'R',
        0,
        0,
        0,
        2,
        0,
        0,
        0,
        3,
        8,
        2,
        0,
        0,
        0,
        0x36,
        0x88,
        0x49,
        0xd6,
        0,
        0,
        0,
        0,
        'I',
        'D',
        'A',
        'T',
        0x35,
        0xaf,
        0x06,
        0x1e,
        0,
        0,
        0,
        0,
        'I',
        'E',
        'N',
        'D',
        0xae,
        0x42,
        0x60,
        0x82,
    ]

    parsed := png_parse(bytes[..])

    on parsed {
        Ok(png) => {
            assert png.ihdr.width == 2, "width"
            assert png.ihdr.height == 3, "height"
            assert png.ihdr.bit_depth == 8, "bit depth"
            assert png.ihdr.color_type == 2, "color type"
            assert png.idat_chunks.count == 1, "idat chunk count"
            assert png.idat_chunks[0].count == 0, "empty idat count"
            png.free()
        }
        else => {
        }
    }
}

test "png reads IHDR chunk" {
    bytes: [25]u8 = [
        0,
        0,
        0,
        13,
        'I',
        'H',
        'D',
        'R',
        0,
        0,
        0,
        2,
        0,
        0,
        0,
        3,
        8,
        2,
        0,
        0,
        0,
        0x36,
        0x88,
        0x49,
        0xd6,
    ]
    reader := ImageReader.new(bytes[..])

    chunk := png_read_chunk(^reader)

    on chunk {
        Ok(value) => {
            assert value.length == 13
            assert value.kind == PNG_CHUNK_IHDR
            assert value.data.count == 13
            assert value.crc == 914901462.as(u32)
        }
        else => {
            assert no
        }
    }
}

test "png computes chunk CRC" {
    ihdr: [13]u8 = [
        0,
        0,
        0,
        2,
        0,
        0,
        0,
        3,
        8,
        2,
        0,
        0,
        0,
    ]
    empty : [0]u8 = []

    assert png_chunk_crc(PNG_CHUNK_IHDR, ihdr[..]) == 914901462.as(u32)
    assert png_chunk_crc(PNG_CHUNK_IDAT, empty[..]) == 900662814.as(u32)
    assert png_chunk_crc(PNG_CHUNK_IEND, empty[..]) == 2923585666.as(u32)
}

test "png collects IDAT chunks" {
    bytes: [59]u8 = [
        0x89,
        'P',
        'N',
        'G',
        13,
        10,
        26,
        10,
        0,
        0,
        0,
        13,
        'I',
        'H',
        'D',
        'R',
        0,
        0,
        0,
        1,
        0,
        0,
        0,
        1,
        8,
        6,
        0,
        0,
        0,
        0x1f,
        0x15,
        0xc4,
        0x89,
        0,
        0,
        0,
        2,
        'I',
        'D',
        'A',
        'T',
        10,
        20,
        0x9c,
        0xce,
        0x81,
        0x4d,
        0,
        0,
        0,
        0,
        'I',
        'E',
        'N',
        'D',
        0xae,
        0x42,
        0x60,
        0x82,
    ]

    parsed := png_parse(bytes[..])

    on parsed {
        Ok(png) => {
            assert png.idat_chunks.count == 1
            assert png.idat_chunks[0].count == 2
            assert png.idat_chunks[0][0] == 10
            assert png.idat_chunks[0][1] == 20
            png.free()
        }
        else => {
            assert no
        }
    }
}

test "png IDAT payload can be decompressed" {
    bytes: [70]u8 = [
        0x89,
        'P',
        'N',
        'G',
        13,
        10,
        26,
        10,
        0,
        0,
        0,
        13,
        'I',
        'H',
        'D',
        'R',
        0,
        0,
        0,
        1,
        0,
        0,
        0,
        1,
        8,
        6,
        0,
        0,
        0,
        0x1f,
        0x15,
        0xc4,
        0x89,
        0,
        0,
        0,
        13,
        'I',
        'D',
        'A',
        'T',
        120,
        156,
        99,
        248,
        207,
        192,
        240,
        31,
        0,
        5,
        0,
        1,
        255,
        0x89,
        0x99,
        0x3d,
        0x1d,
        0,
        0,
        0,
        0,
        'I',
        'E',
        'N',
        'D',
        0xae,
        0x42,
        0x60,
        0x82,
    ]

    parsed := png_parse(bytes[..])

    on parsed {
        Ok(png) => {
            decompressed := png.idat_chunks[0].deflate_zlib()
            on decompressed {
                Ok(scanline) => {
                    assert scanline.count == 5
                    assert scanline[0] == 0
                    assert scanline[1] == 255
                    assert scanline[2] == 0
                    assert scanline[3] == 0
                    assert scanline[4] == 255
                    scanline.free()
                }
                else => {
                    assert no
                }
            }
            png.free()
        }
        else => {
            assert no
        }
    }
}

test "png unfilters none scanline" {
    bytes : [7]u8 = [0, 10, 20, 30, 40, 50, 60]

    result := png_unfilter(bytes[..], 2, 1, 3)

    on result {
        Ok(pixels) => {
            assert pixels.count == 6, "count"
            assert pixels[0] == 10, "red 0"
            assert pixels[1] == 20, "green 0"
            assert pixels[2] == 30, "blue 0"
            assert pixels[3] == 40, "red 1"
            assert pixels[4] == 50, "green 1"
            assert pixels[5] == 60, "blue 1"
            pixels.free()
        }
        else => {
            assert no
        }
    }
}

test "png unfilters sub scanline" {
    bytes : [7]u8 = [1, 10, 20, 30, 5, 5, 5]

    result := png_unfilter(bytes[..], 2, 1, 3)

    on result {
        Ok(pixels) => {
            assert pixels[0] == 10
            assert pixels[1] == 20
            assert pixels[2] == 30
            assert pixels[3] == 15
            assert pixels[4] == 25
            assert pixels[5] == 35
            pixels.free()
        }
        else => {
            assert no
        }
    }
}

test "png unfilters up scanline" {
    bytes : [8]u8 = [0, 1, 2, 3, 2, 9, 8, 7]

    result := png_unfilter(bytes[..], 1, 2, 3)

    on result {
        Ok(pixels) => {
            assert pixels[0] == 1
            assert pixels[1] == 2
            assert pixels[2] == 3
            assert pixels[3] == 10
            assert pixels[4] == 10
            assert pixels[5] == 10
            pixels.free()
        }
        else => {
            assert no
        }
    }
}

test "png unfilters average scanline" {
    bytes : [7]u8 = [3, 10, 20, 30, 10, 10, 10]

    result := png_unfilter(bytes[..], 2, 1, 3)

    on result {
        Ok(pixels) => {
            assert pixels[0] == 10
            assert pixels[1] == 20
            assert pixels[2] == 30
            assert pixels[3] == 15
            assert pixels[4] == 20
            assert pixels[5] == 25
            pixels.free()
        }
        else => {
            assert no
        }
    }
}

test "png unfilters paeth scanline" {
    bytes: [14]u8 = [
        0,
        10,
        20,
        30,
        40,
        50,
        60,
        4,
        5,
        5,
        5,
        5,
        5,
        5,
    ]

    result := png_unfilter(bytes[..], 2, 2, 3)

    on result {
        Ok(pixels) => {
            assert pixels[6] == 15
            assert pixels[7] == 25
            assert pixels[8] == 35
            assert pixels[9] == 45
            assert pixels[10] == 55
            assert pixels[11] == 65
            pixels.free()
        }
        else => {
            assert no
        }
    }
}

