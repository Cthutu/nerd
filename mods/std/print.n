-- Standard printing module.
--
-- This is the first repo-owned standard module surface. It still relies on the
-- current module-loading/bootstrap path until general module loading lands, but
-- `pr` and `prn` now live here rather than as global built-ins.

ffi "c" printf (text: string, ...) -> i32

pub pr :: fn(text: string) {
    printf("%.*s", text.count, text.data)
}

pub prn :: fn(text: string) {
    pr(text)
    printf("\n")
}
