-- Standard printing module.
--
-- This file records the target public surface while FFI and module loading are
-- being implemented. Once MS25-MS27 are complete, these declarations should be
-- replaced with Nerd wrappers around C printf and the compiler-known pr/prn
-- built-ins should be removed.

ffi "c" printf (text: string, ...) -> i32

pr :: fn(text: string) {
    printf("%.*s", text.count, text.data)
}

prn :: fn(text: string) {
    pr(text)
    printf("\n")
}
