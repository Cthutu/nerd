gl_get_shader_iv_proc              : GLGetShaderivFn             =
                                                                   gl_stub_get_shader_iv
gl_get_shader_info_log_proc        : GLGetShaderInfoLogFn        =
                                                                   gl_stub_get_shader_info_log
gl_delete_shader_proc              : GLDeleteShaderFn            =
                                                                   gl_stub_delete_shader
gl_create_program_proc             : GLCreateProgramFn           =
                                                                   gl_stub_create_program
gl_attach_shader_proc              : GLAttachShaderFn            =
                                                                   gl_stub_attach_shader
gl_bind_attrib_location_proc       : GLBindAttribLocationFn      =
                                                                   gl_stub_bind_attrib_location
gl_link_program_proc               : GLLinkProgramFn             =
                                                                   gl_stub_link_program
gl_get_program_iv_proc             : GLGetProgramivFn            =
                                                                   gl_stub_get_program_iv
gl_get_program_info_log_proc       : GLGetProgramInfoLogFn       =
                                                                   gl_stub_get_program_info_log
gl_delete_program_proc             : GLDeleteProgramFn           =
                                                                   gl_stub_delete_program
