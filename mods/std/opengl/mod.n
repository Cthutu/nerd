                                               value  : GLint)
        pub                  glPixelStorei    (name: GLenum, value: GLint)
        pub                  glTexImage2D     (target          : GLenum,
                                               level           : GLint,
                                               internal_format : GLint,
                                               width           : GLsizei,
                                               height          : GLsizei,
                                               border          : GLint,
                                               format          : GLenum,
                                               type            : GLenum,
                                               pixels          : ^void)
        pub                  glTexSubImage2D  (target  : GLenum,
                                               level   : GLint,
                                               xoffset : GLint,
                                               yoffset : GLint,
                                               width   : GLsizei,
                                               height  : GLsizei,
                                               format  : GLenum,
                                               type    : GLenum,
                                               pixels  : ^void)
        pub                  glDrawArrays     (mode  : GLenum,
                                               first : GLint,
                                               count : GLsizei)
        pub                  glBegin          (mode: GLenum)
        pub                  glEnd            ()
        pub                  glTexCoord2f     (s: GLfloat, t: GLfloat)
        pub                  glVertex2f       (x: GLfloat, y: GLfloat)
        pub                  glColor3f        (red   : GLfloat,
                                               green : GLfloat,
                                               blue  : GLfloat)
    }

}

on "windows" {

    ffi "opengl32" {
        pub                  glViewport       (x      : GLint,
                                               y      : GLint,
                                               width  : GLsizei,
                                               height : GLsizei)
        pub                  glDisable        (cap: GLenum)
        pub                  glClearColor     (red   : GLfloat,
                                               green : GLfloat,
                                               blue  : GLfloat,
                                               alpha : GLfloat)
        pub                  glClear          (mask: GLbitfield)
        pub                  glClearDepth     (depth: GLdouble)
        pub                  glClearStencil   (value: GLint)
        pub                  glDrawBuffer     (buffer: GLenum)
        pub                  glReadBuffer     (buffer: GLenum)
        pub                  glMatrixMode     (mode: GLenum)
        pub                  glLoadIdentity   ()
        pub                  glOrtho          (left   : GLdouble,
                                               right  : GLdouble,
                                               bottom : GLdouble,
                                               top    : GLdouble,
                                               near   : GLdouble,
                                               far    : GLdouble)
        pub                  glEnable         (cap: GLenum)
        pub                  glBlendFunc      (source_factor      : GLenum,
                                               destination_factor : GLenum)
        pub                  glColorMask      (red   : GLboolean,
                                               green : GLboolean,
                                               blue  : GLboolean,
                                               alpha : GLboolean)
        pub                  glCullFace       (mode: GLenum)
        pub                  glDepthFunc      (func: GLenum)
        pub                  glDepthMask      (flag: GLboolean)
        pub                  glFinish         ()
        pub                  glFlush          ()
        pub                  glFrontFace      (mode: GLenum)
        pub                  glGetError       () -> GLenum
        pub                  glGetBooleanv    (name: GLenum, data: ^GLboolean)
        pub                  glGetDoublev     (name: GLenum, data: ^GLdouble)
        pub                  glGetFloatv      (name: GLenum, data: ^GLfloat)
        pub                  glGetIntegerv    (name: GLenum, data: ^GLint)
        gl_get_string_raw :: glGetString      (name: GLenum) -> ^u8
        pub                  glIsEnabled      (cap: GLenum) -> GLboolean
        pub                  glLineWidth      (width: GLfloat)
        pub                  glPointSize      (size: GLfloat)
        pub                  glReadPixels     (x      : GLint,
                                               y      : GLint,
                                               width  : GLsizei,
                                               height : GLsizei,
                                               format : GLenum,
                                               type   : GLenum,
                                               pixels : ^void)
        pub                  glScissor        (x      : GLint,
                                               y      : GLint,
                                               width  : GLsizei,
                                               height : GLsizei)
        pub                  glGenTextures    (count    : GLsizei,
                                               textures : ^GLuint)
        pub                  glDeleteTextures (count    : GLsizei,
                                               textures : ^GLuint)
        pub                  glBindTexture    (target: GLenum, texture: GLuint)
        pub                  glTexParameteri  (target : GLenum,
                                               name   : GLenum,
                                               value  : GLint)
        pub                  glPixelStorei    (name: GLenum, value: GLint)
        pub                  glTexImage2D     (target          : GLenum,
                                               level           : GLint,
                                               internal_format : GLint,
                                               width           : GLsizei,
                                               height          : GLsizei,
                                               border          : GLint,
                                               format          : GLenum,
                                               type            : GLenum,
                                               pixels          : ^void)
        pub                  glTexSubImage2D  (target  : GLenum,
                                               level   : GLint,
                                               xoffset : GLint,
                                               yoffset : GLint,
                                               width   : GLsizei,
                                               height  : GLsizei,
                                               format  : GLenum,
                                               type    : GLenum,
                                               pixels  : ^void)
        pub                  glDrawArrays     (mode  : GLenum,
                                               first : GLint,
                                               count : GLsizei)
        pub                  glBegin          (mode: GLenum)
        pub                  glEnd            ()
        pub                  glTexCoord2f     (s: GLfloat, t: GLfloat)
        pub                  glVertex2f       (x: GLfloat, y: GLfloat)
        pub                  glColor3f        (red   : GLfloat,
                                               green : GLfloat,
                                               blue  : GLfloat)
    }

}

gl_load_commands :: fn (resolve: GLGetProcAddressFn = gl_get_proc_address) -> bool {
    on gl_commands_loaded => return yes

    active_texture := resolve(c"glActiveTexture")
    create_shader := resolve(c"glCreateShader")
    shader_source := resolve(c"glShaderSource")
    compile_shader := resolve(c"glCompileShader")
    get_shader_iv := resolve(c"glGetShaderiv")
    get_shader_info_log := resolve(c"glGetShaderInfoLog")
    delete_shader := resolve(c"glDeleteShader")
    create_program := resolve(c"glCreateProgram")
    attach_shader := resolve(c"glAttachShader")
    bind_attrib_location := resolve(c"glBindAttribLocation")
    link_program := resolve(c"glLinkProgram")
    get_program_iv := resolve(c"glGetProgramiv")
    get_program_info_log := resolve(c"glGetProgramInfoLog")
    delete_program := resolve(c"glDeleteProgram")
    use_program := resolve(c"glUseProgram")
    get_uniform_location := resolve(c"glGetUniformLocation")
    uniform_1f := resolve(c"glUniform1f")
    uniform_2f := resolve(c"glUniform2f")
    uniform_3f := resolve(c"glUniform3f")
    uniform_4f := resolve(c"glUniform4f")
    uniform_1i := resolve(c"glUniform1i")
    uniform_2i := resolve(c"glUniform2i")
    uniform_3i := resolve(c"glUniform3i")
    uniform_4i := resolve(c"glUniform4i")
    uniform_1fv := resolve(c"glUniform1fv")
    uniform_2fv := resolve(c"glUniform2fv")
    uniform_3fv := resolve(c"glUniform3fv")
    uniform_4fv := resolve(c"glUniform4fv")
    uniform_1iv := resolve(c"glUniform1iv")
    uniform_2iv := resolve(c"glUniform2iv")
    uniform_3iv := resolve(c"glUniform3iv")
    uniform_4iv := resolve(c"glUniform4iv")
    uniform_matrix_2fv := resolve(c"glUniformMatrix2fv")
    uniform_matrix_3fv := resolve(c"glUniformMatrix3fv")
    uniform_matrix_4fv := resolve(c"glUniformMatrix4fv")
    gen_buffers := resolve(c"glGenBuffers")
    delete_buffers := resolve(c"glDeleteBuffers")
    bind_buffer := resolve(c"glBindBuffer")
    buffer_data := resolve(c"glBufferData")
    buffer_sub_data := resolve(c"glBufferSubData")
    gen_vertex_arrays := resolve(c"glGenVertexArrays")
    delete_vertex_arrays := resolve(c"glDeleteVertexArrays")
    bind_vertex_array := resolve(c"glBindVertexArray")
    enable_vertex_attrib_array := resolve(c"glEnableVertexAttribArray")
    draw_elements := resolve(c"glDrawElements")
    polygon_mode := resolve(c"glPolygonMode")
    vertex_attrib_pointer := resolve(c"glVertexAttribPointer")
    blend_equation_separate := resolve(c"glBlendEquationSeparate")
    blend_color := resolve(c"glBlendColor")
    blend_func_separate := resolve(c"glBlendFuncSeparate")
    stencil_func_separate := resolve(c"glStencilFuncSeparate")
    stencil_op_separate := resolve(c"glStencilOpSeparate")
    stencil_mask_separate := resolve(c"glStencilMaskSeparate")
    draw_buffers := resolve(c"glDrawBuffers")
    get_string_i := resolve(c"glGetStringi")
    tex_image_3d := resolve(c"glTexImage3D")
    tex_sub_image_3d := resolve(c"glTexSubImage3D")
    generate_mipmap := resolve(c"glGenerateMipmap")
    is_renderbuffer := resolve(c"glIsRenderbuffer")
    bind_renderbuffer := resolve(c"glBindRenderbuffer")
    delete_renderbuffers := resolve(c"glDeleteRenderbuffers")
    gen_renderbuffers := resolve(c"glGenRenderbuffers")
    renderbuffer_storage := resolve(c"glRenderbufferStorage")
    get_renderbuffer_parameter_iv := resolve(c"glGetRenderbufferParameteriv")
    is_framebuffer := resolve(c"glIsFramebuffer")
    bind_framebuffer := resolve(c"glBindFramebuffer")
    delete_framebuffers := resolve(c"glDeleteFramebuffers")
    gen_framebuffers := resolve(c"glGenFramebuffers")
    check_framebuffer_status := resolve(c"glCheckFramebufferStatus")
    framebuffer_texture_2d := resolve(c"glFramebufferTexture2D")
    framebuffer_renderbuffer := resolve(c"glFramebufferRenderbuffer")
    get_framebuffer_attachment_parameter_iv := resolve(c"glGetFramebufferAttachmentParameteriv")
    blit_framebuffer := resolve(c"glBlitFramebuffer")
    renderbuffer_storage_multisample := resolve(c"glRenderbufferStorageMultisample")
    framebuffer_texture_layer := resolve(c"glFramebufferTextureLayer")
    map_buffer_range := resolve(c"glMapBufferRange")
    flush_mapped_buffer_range := resolve(c"glFlushMappedBufferRange")
    disable_vertex_attrib_array := resolve(c"glDisableVertexAttribArray")
    is_vertex_array := resolve(c"glIsVertexArray")

    on active_texture == nil ||
        create_shader == nil ||
        shader_source == nil ||
        compile_shader == nil ||
        get_shader_iv == nil ||
        get_shader_info_log == nil ||
        delete_shader == nil ||
        create_program == nil ||
        attach_shader == nil ||
        bind_attrib_location == nil ||
        link_program == nil ||
        get_program_iv == nil ||
        get_program_info_log == nil ||
        delete_program == nil ||
        use_program == nil ||
        get_uniform_location == nil ||
        uniform_1f == nil ||
        uniform_2f == nil ||
        uniform_3f == nil ||
        uniform_4f == nil ||
        uniform_1i == nil ||
        uniform_2i == nil ||
        uniform_3i == nil ||
        uniform_4i == nil ||
        uniform_1fv == nil ||
        uniform_2fv == nil ||
        uniform_3fv == nil ||
        uniform_4fv == nil ||
        uniform_1iv == nil ||
        uniform_2iv == nil ||
        uniform_3iv == nil ||
        uniform_4iv == nil ||
        uniform_matrix_2fv == nil ||
        uniform_matrix_3fv == nil ||
        uniform_matrix_4fv == nil ||
        gen_buffers == nil ||
        delete_buffers == nil ||
        bind_buffer == nil ||
        buffer_data == nil ||
        buffer_sub_data == nil ||
        gen_vertex_arrays == nil ||
        delete_vertex_arrays == nil ||
        bind_vertex_array == nil ||
        enable_vertex_attrib_array == nil ||
        draw_elements == nil ||
        polygon_mode == nil ||
        vertex_attrib_pointer == nil ||
        blend_equation_separate == nil ||
        blend_color == nil ||
        blend_func_separate == nil ||
        stencil_func_separate == nil ||
        stencil_op_separate == nil ||
        stencil_mask_separate == nil ||
        draw_buffers == nil ||
        get_string_i == nil ||
        tex_image_3d == nil ||
        tex_sub_image_3d == nil ||
        generate_mipmap == nil ||
        is_renderbuffer == nil ||
        bind_renderbuffer == nil ||
        delete_renderbuffers == nil ||
        gen_renderbuffers == nil ||
        renderbuffer_storage == nil ||
        get_renderbuffer_parameter_iv == nil ||
        is_framebuffer == nil ||
        bind_framebuffer == nil ||
        delete_framebuffers == nil ||
        gen_framebuffers == nil ||
        check_framebuffer_status == nil ||
        framebuffer_texture_2d == nil ||
        framebuffer_renderbuffer == nil ||
        get_framebuffer_attachment_parameter_iv == nil ||
        blit_framebuffer == nil ||
        renderbuffer_storage_multisample == nil ||
        framebuffer_texture_layer == nil ||
        map_buffer_range == nil ||
        flush_mapped_buffer_range == nil ||
        disable_vertex_attrib_array == nil ||
        is_vertex_array == nil => return no

    gl_active_texture_proc                          = active_texture.as(GLActiveTextureFn)
    gl_create_shader_proc                           = create_shader.as(GLCreateShaderFn)
    gl_shader_source_proc                           = shader_source.as(GLShaderSourceFn)
    gl_compile_shader_proc                          = compile_shader.as(GLCompileShaderFn)
    gl_get_shader_iv_proc                           = get_shader_iv.as(GLGetShaderivFn)
    gl_get_shader_info_log_proc                     = get_shader_info_log.as(GLGetShaderInfoLogFn)
    gl_delete_shader_proc                           = delete_shader.as(GLDeleteShaderFn)
    gl_create_program_proc                          = create_program.as(GLCreateProgramFn)
    gl_attach_shader_proc                           = attach_shader.as(GLAttachShaderFn)
    gl_bind_attrib_location_proc                    = bind_attrib_location.as(GLBindAttribLocationFn)
    gl_link_program_proc                            = link_program.as(GLLinkProgramFn)
    gl_get_program_iv_proc                          = get_program_iv.as(GLGetProgramivFn)
    gl_get_program_info_log_proc                    = get_program_info_log.as(GLGetProgramInfoLogFn)
    gl_delete_program_proc                          = delete_program.as(GLDeleteProgramFn)
    gl_use_program_proc                             = use_program.as(GLUseProgramFn)
    gl_get_uniform_location_proc                    = get_uniform_location.as(GLGetUniformLocationFn)
    gl_uniform_1f_proc                              = uniform_1f.as(GLUniform1fFn)
    gl_uniform_2f_proc                              = uniform_2f.as(GLUniform2fFn)
    gl_uniform_3f_proc                              = uniform_3f.as(GLUniform3fFn)
    gl_uniform_4f_proc                              = uniform_4f.as(GLUniform4fFn)
    gl_uniform_1i_proc                              = uniform_1i.as(GLUniform1iFn)
    gl_uniform_2i_proc                              = uniform_2i.as(GLUniform2iFn)
    gl_uniform_3i_proc                              = uniform_3i.as(GLUniform3iFn)
    gl_uniform_4i_proc                              = uniform_4i.as(GLUniform4iFn)
    gl_uniform_1fv_proc                             = uniform_1fv.as(GLUniform1fvFn)
    gl_uniform_2fv_proc                             = uniform_2fv.as(GLUniform2fvFn)
    gl_uniform_3fv_proc                             = uniform_3fv.as(GLUniform3fvFn)
    gl_uniform_4fv_proc                             = uniform_4fv.as(GLUniform4fvFn)
    gl_uniform_1iv_proc                             = uniform_1iv.as(GLUniform1ivFn)
    gl_uniform_2iv_proc                             = uniform_2iv.as(GLUniform2ivFn)
    gl_uniform_3iv_proc                             = uniform_3iv.as(GLUniform3ivFn)
    gl_uniform_4iv_proc                             = uniform_4iv.as(GLUniform4ivFn)
    gl_uniform_matrix_2fv_proc                      = uniform_matrix_2fv.as(GLUniformMatrix2fvFn)
    gl_uniform_matrix_3fv_proc                      = uniform_matrix_3fv.as(GLUniformMatrix3fvFn)
    gl_uniform_matrix_4fv_proc                      = uniform_matrix_4fv.as(GLUniformMatrix4fvFn)
    gl_gen_buffers_proc                             = gen_buffers.as(GLGenBuffersFn)
    gl_delete_buffers_proc                          = delete_buffers.as(GLDeleteBuffersFn)
    gl_bind_buffer_proc                             = bind_buffer.as(GLBindBufferFn)
    gl_buffer_data_proc                             = buffer_data.as(GLBufferDataFn)
    gl_buffer_sub_data_proc                         = buffer_sub_data.as(GLBufferSubDataFn)
    gl_gen_vertex_arrays_proc                       = gen_vertex_arrays.as(GLGenVertexArraysFn)
    gl_delete_vertex_arrays_proc                    = delete_vertex_arrays.as(GLDeleteVertexArraysFn)
    gl_bind_vertex_array_proc                       = bind_vertex_array.as(GLBindVertexArrayFn)
    gl_enable_vertex_attrib_array_proc              = enable_vertex_attrib_array.as(GLEnableVertexAttribArrayFn)
    gl_draw_elements_proc                           = draw_elements.as(GLDrawElementsFn)
    gl_polygon_mode_proc                            = polygon_mode.as(GLPolygonModeFn)
    gl_vertex_attrib_pointer_proc                   = vertex_attrib_pointer.as(GLVertexAttribPointerFn)
    gl_blend_equation_separate_proc                 = blend_equation_separate.as(GLBlendEquationSeparateFn)
    gl_blend_color_proc                             = blend_color.as(GLBlendColorFn)
    gl_blend_func_separate_proc                     = blend_func_separate.as(GLBlendFuncSeparateFn)
    gl_stencil_func_separate_proc                   = stencil_func_separate.as(GLStencilFuncSeparateFn)
    gl_stencil_op_separate_proc                     = stencil_op_separate.as(GLStencilOpSeparateFn)
    gl_stencil_mask_separate_proc                   = stencil_mask_separate.as(GLStencilMaskSeparateFn)
    gl_draw_buffers_proc                            = draw_buffers.as(GLDrawBuffersFn)
    gl_get_string_i_proc                            = get_string_i.as(GLGetStringiFn)
    gl_tex_image_3d_proc                            = tex_image_3d.as(GLTexImage3DFn)
    gl_tex_sub_image_3d_proc                        = tex_sub_image_3d.as(GLTexSubImage3DFn)
    gl_generate_mipmap_proc                         = generate_mipmap.as(GLGenerateMipmapFn)
    gl_is_renderbuffer_proc                         = is_renderbuffer.as(GLIsRenderbufferFn)
    gl_bind_renderbuffer_proc                       = bind_renderbuffer.as(GLBindRenderbufferFn)
    gl_delete_renderbuffers_proc                    = delete_renderbuffers.as(GLDeleteRenderbuffersFn)
    gl_gen_renderbuffers_proc                       = gen_renderbuffers.as(GLGenRenderbuffersFn)
    gl_renderbuffer_storage_proc                    = renderbuffer_storage.as(GLRenderbufferStorageFn)
    gl_get_renderbuffer_parameter_iv_proc           = get_renderbuffer_parameter_iv.as(GLGetRenderbufferParameterivFn)
    gl_is_framebuffer_proc                          = is_framebuffer.as(GLIsFramebufferFn)
    gl_bind_framebuffer_proc                        = bind_framebuffer.as(GLBindFramebufferFn)
    gl_delete_framebuffers_proc                     = delete_framebuffers.as(GLDeleteFramebuffersFn)
    gl_gen_framebuffers_proc                        = gen_framebuffers.as(GLGenFramebuffersFn)
    gl_check_framebuffer_status_proc                = check_framebuffer_status.as(GLCheckFramebufferStatusFn)
    gl_framebuffer_texture_2d_proc                  = framebuffer_texture_2d.as(GLFramebufferTexture2DFn)
    gl_framebuffer_renderbuffer_proc                = framebuffer_renderbuffer.as(GLFramebufferRenderbufferFn)
    gl_get_framebuffer_attachment_parameter_iv_proc = get_framebuffer_attachment_parameter_iv.as(GLGetFramebufferAttachmentParameterivFn)
    gl_blit_framebuffer_proc                        = blit_framebuffer.as(GLBlitFramebufferFn)
    gl_renderbuffer_storage_multisample_proc        = renderbuffer_storage_multisample.as(GLRenderbufferStorageMultisampleFn)
    gl_framebuffer_texture_layer_proc               = framebuffer_texture_layer.as(GLFramebufferTextureLayerFn)
    gl_map_buffer_range_proc                        = map_buffer_range.as(GLMapBufferRangeFn)
    gl_flush_mapped_buffer_range_proc               = flush_mapped_buffer_range.as(GLFlushMappedBufferRangeFn)
    gl_disable_vertex_attrib_array_proc             = disable_vertex_attrib_array.as(GLDisableVertexAttribArrayFn)
    gl_is_vertex_array_proc                         = is_vertex_array.as(GLIsVertexArrayFn)

    gl_commands_loaded = yes
    return yes
}

