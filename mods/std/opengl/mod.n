-- Nerd Standard Library (NSL)
--
-- Copyright (c) 2026 Matt Davies
--
-- Provides the public OpenGL surface exposed by the standard library. Platform
-- frame backends create and bind contexts; this module owns command loading and
-- the cross-platform command API.

use core
use std.frame

on "linux" {

    use os.linux.glx

    gl_get_proc_address :: fn (name: ^i8) -> ^void {
        return glXGetProcAddress(name)
    }

}

on "windows" {

    use os.windows

    gl_get_proc_address :: fn (name: ^i8) -> ^void {
        return wglGetValidProcAddress(name)
    }

}

-- OpenGL enum value.
pub GLenum :: u32

-- OpenGL boolean value.
pub GLboolean :: u8

-- OpenGL signed integer value.
pub GLint :: i32

-- OpenGL unsigned integer value.
pub GLuint :: u32

-- OpenGL size value.
pub GLsizei :: i32

-- OpenGL single-precision floating-point value.
pub GLfloat :: f32

-- OpenGL double-precision floating-point value.
pub GLdouble :: f64

-- OpenGL bitfield value.
pub GLbitfield :: u32

-- OpenGL pointer-sized signed offset/size values.
pub GLintptr   :: isize
pub GLsizeiptr :: isize

pub GL_FALSE :: 0
pub GL_TRUE  :: 1

pub GL_COLOR_BUFFER_BIT :: 0x00004000

pub GL_TEXTURE_2D     :: 0x0de1
pub GL_QUADS          :: 0x0007
pub GL_TRIANGLES      :: 0x0004
pub GL_TRIANGLE_STRIP :: 0x0005

pub GL_PROJECTION :: 0x1701
pub GL_MODELVIEW  :: 0x1700

pub GL_DEPTH_TEST :: 0x0b71

pub GL_TEXTURE_MIN_FILTER :: 0x2801
pub GL_TEXTURE_MAG_FILTER :: 0x2800
pub GL_TEXTURE_WRAP_S     :: 0x2802
pub GL_TEXTURE_WRAP_T     :: 0x2803

pub GL_NEAREST       :: 0x2600
pub GL_CLAMP_TO_EDGE :: 0x812f

pub GL_FLOAT :: 0x1406

pub GL_RGBA          :: 0x1908
pub GL_BGRA          :: 0x80e1
pub GL_UNSIGNED_BYTE :: 0x1401

pub GL_UNPACK_ALIGNMENT  :: 0x0cf5
pub GL_UNPACK_ROW_LENGTH :: 0x0cf2

pub GL_TEXTURE0 :: 0x84c0

pub GL_ARRAY_BUFFER         :: 0x8892
pub GL_ELEMENT_ARRAY_BUFFER :: 0x8893
pub GL_DYNAMIC_DRAW         :: 0x88e8
pub GL_STATIC_DRAW          :: 0x88e4

pub GL_VERTEX_SHADER   :: 0x8b31
pub GL_FRAGMENT_SHADER :: 0x8b30
pub GL_COMPILE_STATUS  :: 0x8b81
pub GL_LINK_STATUS     :: 0x8b82
pub GL_INFO_LOG_LENGTH :: 0x8b84

GLActiveTextureFn           :: fn (texture: GLenum)
GLCreateShaderFn            :: fn (type: GLenum) -> GLuint
GLShaderSourceFn            :: fn (shader  : GLuint,
                                   count   : GLsizei,
                                   strings : ^^i8,
                                   lengths : ^GLint)
GLCompileShaderFn           :: fn (shader: GLuint)
GLGetShaderivFn             :: fn (shader: GLuint, name: GLenum, values: ^GLint)
GLGetShaderInfoLogFn        :: fn (shader : GLuint,
                                   size   : GLsizei,
                                   length : ^GLsizei,
                                   log    : ^i8)
GLDeleteShaderFn            :: fn (shader: GLuint)
GLCreateProgramFn           :: fn () -> GLuint
GLAttachShaderFn            :: fn (program: GLuint, shader: GLuint)
GLBindAttribLocationFn      :: fn (program: GLuint, index: GLuint, name: ^i8)
GLLinkProgramFn             :: fn (program: GLuint)
GLGetProgramivFn            ::
                               fn (program : GLuint,
                                   name    : GLenum,
                                   values  : ^GLint)
GLGetProgramInfoLogFn       :: fn (program : GLuint,
                                   size    : GLsizei,
                                   length  : ^GLsizei,
                                   log     : ^i8)
GLDeleteProgramFn           :: fn (program: GLuint)
GLUseProgramFn              :: fn (program: GLuint)
GLGetUniformLocationFn      :: fn (program: GLuint, name: ^i8) -> GLint
GLUniform1iFn               :: fn (location: GLint, value: GLint)
GLGenBuffersFn              :: fn (count: GLsizei, buffers: ^GLuint)
GLDeleteBuffersFn           :: fn (count: GLsizei, buffers: ^GLuint)
GLBindBufferFn              :: fn (target: GLenum, buffer: GLuint)
GLBufferDataFn              :: fn (target : GLenum,
                                   size   : GLsizeiptr,
                                   data   : ^void,
                                   usage  : GLenum)
GLBufferSubDataFn           :: fn (target : GLenum,
                                   offset : GLintptr,
                                   size   : GLsizeiptr,
                                   data   : ^void)
GLGenVertexArraysFn         :: fn (count: GLsizei, arrays: ^GLuint)
GLDeleteVertexArraysFn      :: fn (count: GLsizei, arrays: ^GLuint)
GLBindVertexArrayFn         :: fn (array: GLuint)
GLEnableVertexAttribArrayFn :: fn (index: GLuint)

GLVertexAttribPointerFn :: fn (index      : GLuint,
                               size       : GLint,
                               type       : GLenum,
                               normalized : GLboolean,
                               stride     : GLsizei,
                               pointer    : ^void)

gl_abort_unloaded_command :: fn () {
    abort("OpenGL command called before address loading completed.")
}

gl_stub_active_texture :: fn (_texture: GLenum) {
    gl_abort_unloaded_command()
}

gl_stub_create_shader :: fn (_type: GLenum) -> GLuint {
    gl_abort_unloaded_command()
    return 0
}

