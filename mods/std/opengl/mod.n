gl_commands_loaded := no

on "linux" {

    ffi "GL" {
        pub glViewport       (x      : GLint,
                              y      : GLint,
                              width  : GLsizei,
                              height : GLsizei)
        pub glDisable        (cap: GLenum)
        pub glClearColor     (red   : GLfloat,
                              green : GLfloat,
                              blue  : GLfloat,
                              alpha : GLfloat)
        pub glClear          (mask: GLbitfield)
        pub glMatrixMode     (mode: GLenum)
        pub glLoadIdentity   ()
        pub glOrtho          (left   : GLdouble,
                              right  : GLdouble,
                              bottom : GLdouble,
                              top    : GLdouble,
                              near   : GLdouble,
                              far    : GLdouble)
        pub glEnable         (cap: GLenum)
        pub glGenTextures    (count: GLsizei, textures: ^GLuint)
        pub glDeleteTextures (count: GLsizei, textures: ^GLuint)
        pub glBindTexture    (target: GLenum, texture: GLuint)
        pub glTexParameteri  (target: GLenum, name: GLenum, value: GLint)
        pub glPixelStorei    (name: GLenum, value: GLint)
        pub glTexImage2D     (target          : GLenum,
                              level           : GLint,
                              internal_format : GLint,
                              width           : GLsizei,
                              height          : GLsizei,
                              border          : GLint,
                              format          : GLenum,
                              type            : GLenum,
                              pixels          : ^void)
        pub glTexSubImage2D  (target  : GLenum,
                              level   : GLint,
                              xoffset : GLint,
                              yoffset : GLint,
                              width   : GLsizei,
                              height  : GLsizei,
                              format  : GLenum,
                              type    : GLenum,
                              pixels  : ^void)
        pub glDrawArrays     (mode: GLenum, first: GLint, count: GLsizei)
        pub glBegin          (mode: GLenum)
        pub glEnd            ()
        pub glTexCoord2f     (s: GLfloat, t: GLfloat)
        pub glVertex2f       (x: GLfloat, y: GLfloat)
    }

}

on "windows" {

    ffi "opengl32" {
        pub glViewport       (x      : GLint,
                              y      : GLint,
                              width  : GLsizei,
                              height : GLsizei)
        pub glDisable        (cap: GLenum)
        pub glClearColor     (red   : GLfloat,
                              green : GLfloat,
                              blue  : GLfloat,
                              alpha : GLfloat)
        pub glClear          (mask: GLbitfield)
        pub glMatrixMode     (mode: GLenum)
        pub glLoadIdentity   ()
        pub glOrtho          (left   : GLdouble,
                              right  : GLdouble,
                              bottom : GLdouble,
                              top    : GLdouble,
                              near   : GLdouble,
                              far    : GLdouble)
        pub glEnable         (cap: GLenum)
        pub glGenTextures    (count: GLsizei, textures: ^GLuint)
        pub glDeleteTextures (count: GLsizei, textures: ^GLuint)
        pub glBindTexture    (target: GLenum, texture: GLuint)
        pub glTexParameteri  (target: GLenum, name: GLenum, value: GLint)
        pub glPixelStorei    (name: GLenum, value: GLint)
        pub glTexImage2D     (target          : GLenum,
                              level           : GLint,
                              internal_format : GLint,
                              width           : GLsizei,
                              height          : GLsizei,
                              border          : GLint,
                              format          : GLenum,
                              type            : GLenum,
                              pixels          : ^void)
        pub glTexSubImage2D  (target  : GLenum,
                              level   : GLint,
                              xoffset : GLint,
                              yoffset : GLint,
                              width   : GLsizei,
                              height  : GLsizei,
                              format  : GLenum,
                              type    : GLenum,
                              pixels  : ^void)
        pub glDrawArrays     (mode: GLenum, first: GLint, count: GLsizei)
        pub glBegin          (mode: GLenum)
        pub glEnd            ()
        pub glTexCoord2f     (s: GLfloat, t: GLfloat)
        pub glVertex2f       (x: GLfloat, y: GLfloat)
        pub glColor3f        (red: GLfloat, green: GLfloat, blue: GLfloat)
    }

}

gl_load_commands :: fn () -> bool {
    on gl_commands_loaded => return yes

    active_texture := gl_get_proc_address(c"glActiveTexture")
    create_shader := gl_get_proc_address(c"glCreateShader")
    shader_source := gl_get_proc_address(c"glShaderSource")
    compile_shader := gl_get_proc_address(c"glCompileShader")
    get_shader_iv := gl_get_proc_address(c"glGetShaderiv")
    get_shader_info_log := gl_get_proc_address(c"glGetShaderInfoLog")
    delete_shader := gl_get_proc_address(c"glDeleteShader")
    create_program := gl_get_proc_address(c"glCreateProgram")
    attach_shader := gl_get_proc_address(c"glAttachShader")
    bind_attrib_location := gl_get_proc_address(c"glBindAttribLocation")
    link_program := gl_get_proc_address(c"glLinkProgram")
    get_program_iv := gl_get_proc_address(c"glGetProgramiv")
    get_program_info_log := gl_get_proc_address(c"glGetProgramInfoLog")
    delete_program := gl_get_proc_address(c"glDeleteProgram")
    use_program := gl_get_proc_address(c"glUseProgram")
    get_uniform_location := gl_get_proc_address(c"glGetUniformLocation")
    uniform_1i := gl_get_proc_address(c"glUniform1i")
    gen_buffers := gl_get_proc_address(c"glGenBuffers")
    delete_buffers := gl_get_proc_address(c"glDeleteBuffers")
    bind_buffer := gl_get_proc_address(c"glBindBuffer")
    buffer_data := gl_get_proc_address(c"glBufferData")
    buffer_sub_data := gl_get_proc_address(c"glBufferSubData")
    gen_vertex_arrays := gl_get_proc_address(c"glGenVertexArrays")
    delete_vertex_arrays := gl_get_proc_address(c"glDeleteVertexArrays")
    bind_vertex_array := gl_get_proc_address(c"glBindVertexArray")
    enable_vertex_attrib_array := gl_get_proc_address(c"glEnableVertexAttribArray")
    vertex_attrib_pointer := gl_get_proc_address(c"glVertexAttribPointer")

    on active_texture == nil ||
        create_shader == nil ||
        shader_source == nil ||
        compile_shader == nil ||
        get_shader_iv == nil ||
        get_shader_info_log == nil ||
        delete_shader == nil ||
        create_program == nil ||
        attach_shader == nil ||
        bind_attrib_location == nil ||
        link_program == nil ||
        get_program_iv == nil ||
        get_program_info_log == nil ||
        delete_program == nil ||
        use_program == nil ||
        get_uniform_location == nil ||
        uniform_1i == nil ||
        gen_buffers == nil ||
        delete_buffers == nil ||
        bind_buffer == nil ||
        buffer_data == nil ||
        buffer_sub_data == nil ||
        gen_vertex_arrays == nil ||
        delete_vertex_arrays == nil ||
        bind_vertex_array == nil ||
        enable_vertex_attrib_array == nil ||
        vertex_attrib_pointer == nil => return no

    gl_active_texture_proc             = active_texture.as(GLActiveTextureFn)
    gl_create_shader_proc              = create_shader.as(GLCreateShaderFn)
    gl_shader_source_proc              = shader_source.as(GLShaderSourceFn)
    gl_compile_shader_proc             = compile_shader.as(GLCompileShaderFn)
    gl_get_shader_iv_proc              = get_shader_iv.as(GLGetShaderivFn)
    gl_get_shader_info_log_proc        = get_shader_info_log.as(GLGetShaderInfoLogFn)
    gl_delete_shader_proc              = delete_shader.as(GLDeleteShaderFn)
    gl_create_program_proc             = create_program.as(GLCreateProgramFn)
    gl_attach_shader_proc              = attach_shader.as(GLAttachShaderFn)
    gl_bind_attrib_location_proc       = bind_attrib_location.as(GLBindAttribLocationFn)
    gl_link_program_proc               = link_program.as(GLLinkProgramFn)
    gl_get_program_iv_proc             = get_program_iv.as(GLGetProgramivFn)
    gl_get_program_info_log_proc       = get_program_info_log.as(GLGetProgramInfoLogFn)
    gl_delete_program_proc             = delete_program.as(GLDeleteProgramFn)
    gl_use_program_proc                = use_program.as(GLUseProgramFn)
    gl_get_uniform_location_proc       = get_uniform_location.as(GLGetUniformLocationFn)
    gl_uniform_1i_proc                 = uniform_1i.as(GLUniform1iFn)
    gl_gen_buffers_proc                = gen_buffers.as(GLGenBuffersFn)
    gl_delete_buffers_proc             = delete_buffers.as(GLDeleteBuffersFn)
    gl_bind_buffer_proc                = bind_buffer.as(GLBindBufferFn)
    gl_buffer_data_proc                = buffer_data.as(GLBufferDataFn)
    gl_buffer_sub_data_proc            = buffer_sub_data.as(GLBufferSubDataFn)
    gl_gen_vertex_arrays_proc          = gen_vertex_arrays.as(GLGenVertexArraysFn)
    gl_delete_vertex_arrays_proc       = delete_vertex_arrays.as(GLDeleteVertexArraysFn)
    gl_bind_vertex_array_proc          = bind_vertex_array.as(GLBindVertexArrayFn)
    gl_enable_vertex_attrib_array_proc = enable_vertex_attrib_array.as(GLEnableVertexAttribArrayFn)
    gl_vertex_attrib_pointer_proc      = vertex_attrib_pointer.as(GLVertexAttribPointerFn)

    gl_commands_loaded = yes
    return yes
}

pub gl_reset_commands :: fn () {
    gl_active_texture_proc             = gl_stub_active_texture
    gl_create_shader_proc              = gl_stub_create_shader
    gl_shader_source_proc              = gl_stub_shader_source
    gl_compile_shader_proc             = gl_stub_compile_shader
    gl_get_shader_iv_proc              = gl_stub_get_shader_iv
    gl_get_shader_info_log_proc        = gl_stub_get_shader_info_log
    gl_delete_shader_proc              = gl_stub_delete_shader
    gl_create_program_proc             = gl_stub_create_program
    gl_attach_shader_proc              = gl_stub_attach_shader
    gl_bind_attrib_location_proc       = gl_stub_bind_attrib_location
    gl_link_program_proc               = gl_stub_link_program
    gl_get_program_iv_proc             = gl_stub_get_program_iv
    gl_get_program_info_log_proc       = gl_stub_get_program_info_log
    gl_delete_program_proc             = gl_stub_delete_program
    gl_use_program_proc                = gl_stub_use_program
    gl_get_uniform_location_proc       = gl_stub_get_uniform_location
    gl_uniform_1i_proc                 = gl_stub_uniform_1i
    gl_gen_buffers_proc                = gl_stub_gen_buffers
    gl_delete_buffers_proc             = gl_stub_delete_buffers
    gl_bind_buffer_proc                = gl_stub_bind_buffer
    gl_buffer_data_proc                = gl_stub_buffer_data
    gl_buffer_sub_data_proc            = gl_stub_buffer_sub_data
    gl_gen_vertex_arrays_proc          = gl_stub_gen_vertex_arrays
    gl_delete_vertex_arrays_proc       = gl_stub_delete_vertex_arrays
    gl_bind_vertex_array_proc          = gl_stub_bind_vertex_array
    gl_enable_vertex_attrib_array_proc = gl_stub_enable_vertex_attrib_array
    gl_vertex_attrib_pointer_proc      = gl_stub_vertex_attrib_pointer
    gl_commands_loaded                 = no
}

pub gl_init :: fn (frame: ^Frame) -> bool {
    on frame.context() {
        Ok(_) => {
            on !frame.system.opengl_init(frame) => return no
            return gl_load_commands()
        }
        Err(_) => return no
    }
    return no
}

pub gl_done :: fn (frame: ^Frame) {
    on frame.system == nil => return
    frame.system.opengl_done(frame)
    gl_reset_commands()
}

pub gl_make_current :: fn (frame: ^Frame) -> bool {
    on frame.context() {
        Ok(_)   => return frame.system.opengl_make_current(frame)
        Err(_)  => return no
    }
    return no
}

pub gl_swap_buffers :: fn (frame: ^Frame) {
    on frame.system == nil => return
    frame.system.opengl_swap_buffers(frame)
}

pub glActiveTexture :: fn (texture: GLenum) {
    gl_active_texture_proc(texture)
}

pub glCreateShader :: fn (type: GLenum) -> GLuint {
    return gl_create_shader_proc(type)
}

pub glShaderSource :: fn (shader  : GLuint,
                          count   : GLsizei,
                          strings : ^^i8,
                          lengths : ^GLint) {
    gl_shader_source_proc(shader, count, strings, lengths)
}

pub glCompileShader :: fn (shader: GLuint) {
    gl_compile_shader_proc(shader)
}

pub glGetShaderiv :: fn (shader: GLuint, name: GLenum, values: ^GLint) {
    gl_get_shader_iv_proc(shader, name, values)
}

pub glGetShaderInfoLog :: fn (shader : GLuint,
                              size   : GLsizei,
                              length : ^GLsizei,
                              log    : ^i8) {
    gl_get_shader_info_log_proc(shader, size, length, log)
}

pub glDeleteShader :: fn (shader: GLuint) {
    gl_delete_shader_proc(shader)
}

pub glCreateProgram :: fn () -> GLuint {
    return gl_create_program_proc()
}

pub glAttachShader :: fn (program: GLuint, shader: GLuint) {
    gl_attach_shader_proc(program, shader)
}

pub glBindAttribLocation :: fn (program: GLuint, index: GLuint, name: ^i8) {
    gl_bind_attrib_location_proc(program, index, name)
}

pub glLinkProgram :: fn (program: GLuint) {
    gl_link_program_proc(program)
}

pub glGetProgramiv :: fn (program: GLuint, name: GLenum, values: ^GLint) {
    gl_get_program_iv_proc(program, name, values)
}

pub glGetProgramInfoLog :: fn (program : GLuint,
                               size    : GLsizei,
                               length  : ^GLsizei,
                               log     : ^i8) {
    gl_get_program_info_log_proc(program, size, length, log)
}

pub glDeleteProgram :: fn (program: GLuint) {
    gl_delete_program_proc(program)
}

pub glUseProgram :: fn (program: GLuint) {
    gl_use_program_proc(program)
}

pub glGetUniformLocation :: fn (program: GLuint, name: ^i8) -> GLint {
    return gl_get_uniform_location_proc(program, name)
}

pub glUniform1i :: fn (location: GLint, value: GLint) {
    gl_uniform_1i_proc(location, value)
}

pub glGenBuffers :: fn (count: GLsizei, buffers: ^GLuint) {
    gl_gen_buffers_proc(count, buffers)
}

pub glDeleteBuffers :: fn (count: GLsizei, buffers: ^GLuint) {
    gl_delete_buffers_proc(count, buffers)
}

pub glBindBuffer :: fn (target: GLenum, buffer: GLuint) {
    gl_bind_buffer_proc(target, buffer)
}

pub glBufferData :: fn (target : GLenum,
                        size   : GLsizeiptr,
                        data   : ^void,
                        usage  : GLenum) {
    gl_buffer_data_proc(target, size, data, usage)
}

pub glBufferSubData :: fn (target : GLenum,
                           offset : GLintptr,
                           size   : GLsizeiptr,
                           data   : ^void) {
    gl_buffer_sub_data_proc(target, offset, size, data)
}

pub glGenVertexArrays :: fn (count: GLsizei, arrays: ^GLuint) {
    gl_gen_vertex_arrays_proc(count, arrays)
}

pub glDeleteVertexArrays :: fn (count: GLsizei, arrays: ^GLuint) {
    gl_delete_vertex_arrays_proc(count, arrays)
}

pub glBindVertexArray :: fn (array: GLuint) {
    gl_bind_vertex_array_proc(array)
}

pub glEnableVertexAttribArray :: fn (index: GLuint) {
    gl_enable_vertex_attrib_array_proc(index)
}

pub glVertexAttribPointer :: fn (index      : GLuint,
                                 size       : GLint,
                                 type       : GLenum,
                                 normalized : GLboolean,
                                 stride     : GLsizei,
                                 pointer    : ^void) {
    gl_vertex_attrib_pointer_proc(index,
                                  size,
                                  type,
                                  normalized,
                                  stride,
                                  pointer)
}

test "OpenGL command reset is idempotent" {
    gl_reset_commands()
    gl_reset_commands()
    assert yes
}
