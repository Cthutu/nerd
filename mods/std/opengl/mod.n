                                                                   gl_stub_uniform_1i
gl_gen_buffers_proc                : GLGenBuffersFn              =
                                                                   gl_stub_gen_buffers
gl_delete_buffers_proc             : GLDeleteBuffersFn           =
                                                                   gl_stub_delete_buffers
