test {

    gl_test_missing_proc :: fn (_name: ^i8) -> ^void {
        return nil
    }

    gl_test_present_proc :: fn (_name: ^i8) -> ^void {
        return gl_stub_active_texture.as(^void)
    }

}

test "OpenGL command loading fails atomically when an address is missing" {
    gl_reset_commands()
    assert !gl_load_commands(gl_test_missing_proc)
    assert !gl_commands_loaded
}

test "OpenGL command loading and reset need no window with an injected resolver" {
    gl_reset_commands()
    assert gl_load_commands(gl_test_present_proc)
    assert gl_commands_loaded
    gl_reset_commands()
    assert !gl_commands_loaded
}

test "OpenGL command reset is idempotent" {
    gl_reset_commands()
    gl_reset_commands()
    assert yes
}

test "OpenGL scalar aliases preserve ABI widths" {
    assert GLenum.size == 4
    assert GLboolean.size == 1
    assert GLbyte.size == 1
    assert GLubyte.size == 1
    assert GLshort.size == 2
    assert GLushort.size == 2
    assert GLhalf.size == 2
    assert GLint.size == 4
    assert GLuint.size == 4
    assert GLchar.size == 1
    assert GLsizei.size == 4
    assert GLfloat.size == 4
    assert GLdouble.size == 8
    assert GLbitfield.size == 4
    assert GLintptr.size == usize.size
    assert GLsizeiptr.size == usize.size
}
