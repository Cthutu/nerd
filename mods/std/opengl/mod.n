    gl_framebuffer_texture_layer_proc               = gl_stub_framebuffer_texture_layer
    gl_map_buffer_range_proc                        = gl_stub_map_buffer_range
    gl_flush_mapped_buffer_range_proc               = gl_stub_flush_mapped_buffer_range
    gl_disable_vertex_attrib_array_proc             = gl_stub_disable_vertex_attrib_array
    gl_is_vertex_array_proc                         = gl_stub_is_vertex_array
    gl_commands_loaded                              = no
}

pub gl_init :: fn (frame: ^Frame) -> bool {
    return on frame.context() => {
        on !frame.system.opengl_init(frame) => return no
        on !gl_load_commands() => {
            frame.system.opengl_done(frame)
            gl_reset_commands()
            return no
        }
        break yes
    } else {
        break no
    }
}

pub gl_done :: fn (frame: ^Frame) {
    on frame.system == nil => return
    frame.system.opengl_done(frame)
    gl_reset_commands()
}

pub gl_make_current :: fn (frame: ^Frame) -> bool {
    return on frame.context() => {
        break frame.system.opengl_make_current(frame)
    } else {
        break no
    }
}

pub gl_swap_buffers :: fn (frame: ^Frame) {
    on frame.system == nil => return
    frame.system.opengl_swap_buffers(frame)
}

pub glGetString :: fn (name: GLenum) -> []u8 {
    data := gl_get_string_raw(name)
    on data == nil => return nil

    count : usize = 0
    for data[count] != 0 {
        count += 1
    }

    return data.as([]u8, count)
}

