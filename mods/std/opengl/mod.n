GLIsVertexArrayFn            :: fn (array: GLuint) -> GLboolean
GLGetProcAddressFn           :: fn (name: ^i8) -> ^void

gl_abort_unloaded_command :: fn () {
    abort("OpenGL command called before address loading completed.")
}

gl_stub_active_texture :: fn (_texture: GLenum) {
    gl_abort_unloaded_command()
}

gl_stub_create_shader :: fn (_type: GLenum) -> GLuint {
    gl_abort_unloaded_command()
    return 0
}

gl_stub_shader_source :: fn (_shader  : GLuint,
                             _count   : GLsizei,
                             _strings : ^^i8,
                             _lengths : ^GLint) {
    gl_abort_unloaded_command()
}

gl_stub_compile_shader :: fn (_shader: GLuint) {
    gl_abort_unloaded_command()
}

gl_stub_get_shader_iv :: fn (_shader: GLuint, _name: GLenum, _values: ^GLint) {
    gl_abort_unloaded_command()
}

gl_stub_get_shader_info_log :: fn (_shader : GLuint,
                                   _size   : GLsizei,
                                   _length : ^GLsizei,
                                   _log    : ^i8) {
    gl_abort_unloaded_command()
}

gl_stub_delete_shader :: fn (_shader: GLuint) {
    gl_abort_unloaded_command()
}

gl_stub_create_program :: fn () -> GLuint {
    gl_abort_unloaded_command()
