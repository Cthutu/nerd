on "linux" {

    use os.linux.glx
    use os.linux.x11

    pub FrameContext :: plex {
        display    XDisplay
        window     XWindow
        drawable   GLXDrawable
        gl_context GLXContext
        width      u16
        height     u16
    }

    -- Linux X11 data attached to a public `Frame`.
    PlatformFrameInfo :: plex {
        display             XDisplay    -- Display connection owning the window.
        window              XWindow     -- Native X11 window handle.
        wm_delete_window    XAtom       -- Window-manager close protocol atom.
        wm_state            XAtom       -- EWMH `_NET_WM_STATE` atom.
        wm_state_fullscreen XAtom       -- EWMH fullscreen-state atom.
        frame_extents       XAtom       -- EWMH `_NET_FRAME_EXTENTS` atom.
        x                   i32         -- Last known normal outer-frame x
        --     position.
        y                   i32         -- Last known normal outer-frame y
        --     position.
        width               u16         -- Last known normal width.
        height              u16         -- Last known normal height.
        frame_left          i32         -- Left window-manager decoration
        --     extent.
        frame_top           i32         -- Top window-manager decoration extent.
        restore_x           i32         -- Outer-frame x restored after
        --     fullscreen.
        restore_y           i32         -- Outer-frame y restored after
        --     fullscreen.
        restore_width       u16         -- Width restored after fullscreen.
        restore_height      u16         -- Height restored after fullscreen.
        full_screen         bool        -- Whether this frame is currently
        --     fullscreen.
        resizable           bool        -- Whether user-driven resize is
        --     allowed.
        resize_event_valid  bool        -- Whether a resize has been reported.
        resize_event_width  u16         -- Last width reported via Resized.
        resize_event_height u16         -- Last height reported via Resized.
        gl_context          GLXContext  -- GLX context exposed through
        --     `FrameContext`.
    }

    -- Releases GLX resources attached to a frame record.
    frame_linux_gl_done :: fn (info: ^FrameInfo) {
        on info.platform_info.display == nil ||
            info.platform_info.gl_context == nil => return

        _ := glXMakeCurrent(info.platform_info.display, 0.as(GLXDrawable), nil)
        glXDestroyContext(info.platform_info.display,
                          info.platform_info.gl_context)
        info.platform_info.gl_context = nil
    }

    -- Destroys native X11 resources associated with a frame record.
    frame_linux_destroy_info :: fn (info: ^FrameInfo) {
        frame_linux_gl_done(info)

        on info.platform_info.display != nil && info.platform_info.window != 0 => {
            _ := XDestroyWindow(info.platform_info.display,
                                info.platform_info.window)
            _ := XFlush(info.platform_info.display)
        }

        on info.platform_info.display != nil => {
            _ := XCloseDisplay(info.platform_info.display)
        }

        info.events.free()
        info.id = CLOSED_FRAME
        info.platform_info.display = nil
        info.platform_info.window = 0
        info.platform_info.wm_delete_window = 0
        info.platform_info.wm_state = 0
        info.platform_info.wm_state_fullscreen = 0
        info.platform_info.frame_extents = 0
        info.platform_info.full_screen = no
        info.platform_info.resizable = no
        info.platform_info.gl_context = nil
    }

    frame_context_impl :: fn (frame: ^Frame) -> Result[FrameContext, FrameError] {
        on frame.system == nil => return Err(FrameError.NoSystem)
        on frame.id == CLOSED_FRAME => return Err(FrameError.Closed)

        info := frame_system_find_info(frame.system, frame.id)
        on info == nil ||
            info.platform_info.display == nil ||
            info.platform_info.window == 0 => return Err(FrameError.Invalid)

        return Ok(FrameContext {
            display    : info.platform_info.display
            window     : info.platform_info.window
            drawable   : info.platform_info.window.as(GLXDrawable)
            gl_context : info.platform_info.gl_context
            width      : info.platform_info.width
            height     : info.platform_info.height
        })
    }

    -- Marks a public frame and its platform record as closed.
    frame_linux_mark_closed :: fn (system: ^FrameSystem, frame: ^Frame) {
        id := frame.id
        index := frame_system_find_info_index(system, id)
        frame.id = CLOSED_FRAME
        on index < system.frames.count => {
            frame_linux_destroy_info(^system.frames[index])
            system.frames.swap_delete(index)
        }
    }

    -- Queues a platform-agnostic resize event.
    frame_linux_push_resize :: fn (info: ^FrameInfo, width: u16, height: u16) {
        on width == 0 || height == 0 => return
        on info.platform_info.resize_event_valid &&
            info.platform_info.resize_event_width == width &&
            info.platform_info.resize_event_height == height => return

        info.platform_info.resize_event_valid = yes
        info.platform_info.resize_event_width = width
        info.platform_info.resize_event_height = height
        info.events.push(FrameEvent.Resized {
            width
            height
        })
    }

    -- Records the last known non-fullscreen geometry for later restoration.
    frame_linux_remember_normal_geometry :: fn (info   : ^FrameInfo,
                                                x      : i32,
                                                y      : i32,
                                                width  : u16,
                                                height : u16) {
        info.platform_info.x = x
        info.platform_info.y = y
        info.platform_info.width = width
        info.platform_info.height = height

        on !info.platform_info.full_screen => {
            info.platform_info.restore_x = x
            info.platform_info.restore_y = y
            info.platform_info.restore_width = width
            info.platform_info.restore_height = height
        }
    }

    -- Applies platform resize hints for user-driven window resizing.
    frame_linux_apply_resize_hints :: fn (info: ^FrameInfo, frame: ^Frame) {
        hints : XSizeHints
        info.platform_info.resizable = frame.resizable
        on !frame.resizable => {
            hints.flags = (X_SIZE_HINT_P_MIN_SIZE | X_SIZE_HINT_P_MAX_SIZE).as(XLong)
            hints.min_width = frame.width.as(i32)
            hints.min_height = frame.height.as(i32)
            hints.max_width = frame.width.as(i32)
            hints.max_height = frame.height.as(i32)
        }

        _ := XSetWMNormalHints(info.platform_info.display,
                               info.platform_info.window,
                               ^hints)
    }

    -- Refreshes the window-manager decoration extents used to convert client
    -- coordinates into outer-frame coordinates.
    frame_linux_update_frame_extents :: fn (info: ^FrameInfo) {
        actual_type   : XAtom
        actual_format : i32
        item_count    : XULong
        bytes_after   : XULong
        data          : ^u8

        status := XGetWindowProperty(info.platform_info.display,
                                     info.platform_info.window,
                                     info.platform_info.frame_extents,
                                     0,
                                     4,
                                     X_FALSE,
                                     X_ATOM_CARDINAL,
                                     ^actual_type,
                                     ^actual_format,
                                     ^item_count,
                                     ^bytes_after,
                                     ^data)
        on status != X_SUCCESS || data == nil => return
        defer XFree(data.as(^void))

        on actual_type != X_ATOM_CARDINAL ||
            actual_format != 32 ||
            item_count < 4 => return

        extents := data.as(^XULong)
        info.platform_info.frame_left = extents[0].as(i32)
        info.platform_info.frame_top = extents[2].as(i32)
    }

    -- Captures current window geometry, saving the outer-frame position for
    -- later restoration from fullscreen.
    frame_linux_capture_geometry :: fn (info       : ^FrameInfo,
                                        fallback_x : i32,
                                        fallback_y : i32,
                                        width      : u16,
                                        height     : u16) {
        frame_linux_update_frame_extents(info)

        root := XRootWindow(info.platform_info.display,
                            XDefaultScreen(info.platform_info.display))
        client_x := fallback_x
        client_y := fallback_y
        child : XWindow
        translated := XTranslateCoordinates(info.platform_info.display,
                                            info.platform_info.window,
                                            root,
                                            0,
                                            0,
                                            ^client_x,
                                            ^client_y,
                                            ^child)
        on translated == X_FALSE => {
            client_x = fallback_x
            client_y = fallback_y
        }

        frame_linux_remember_normal_geometry(info,
                                             client_x - info.platform_info.frame_left,
                                             client_y - info.platform_info.frame_top,
                                             width,
                                             height)
    }

    -- Sends an EWMH fullscreen-state request to the window manager.
    frame_linux_send_fullscreen :: fn (info: ^FrameInfo, full_screen: bool) {
        event : XEvent
        client := (^event).as(^XClientMessageEvent)
        client.type = X_EVENT_CLIENT_MESSAGE
        client.display = info.platform_info.display
        client.window = info.platform_info.window
        client.message_type = info.platform_info.wm_state
        client.format = 32
        client.data0 = X_NET_WM_STATE_REMOVE.as(XLong)
        on full_screen => client.data0 = X_NET_WM_STATE_ADD.as(XLong)
        client.data1 = info.platform_info.wm_state_fullscreen.as(XLong)
        client.data2 = 0
        client.data3 = 1
        client.data4 = 0

        root := XRootWindow(info.platform_info.display,
                            XDefaultScreen(info.platform_info.display))
        mask := (X_SUBSTRUCTURE_REDIRECT_MASK | X_SUBSTRUCTURE_NOTIFY_MASK).as(XLong)
        _ := XSendEvent(info.platform_info.display, root, 0, mask, ^event)
        _ := XFlush(info.platform_info.display)
    }

    -- Applies `Frame.full_screen`, preserving and restoring normal geometry.
    frame_linux_apply_fullscreen :: fn (info: ^FrameInfo, frame: ^Frame) {
        on frame.full_screen == info.platform_info.full_screen => return

        on frame.full_screen {
            yes => {
                frame_linux_capture_geometry(info,
                                             info.platform_info.x,
                                             info.platform_info.y,
                                             info.platform_info.width,
                                             info.platform_info.height)
                info.platform_info.restore_x = info.platform_info.x
                info.platform_info.restore_y = info.platform_info.y
                info.platform_info.restore_width = info.platform_info.width
                info.platform_info.restore_height = info.platform_info.height
                frame_linux_send_fullscreen(info, yes)
                info.platform_info.full_screen = yes
            }
            no => {
                frame_linux_send_fullscreen(info, no)
                info.platform_info.full_screen = no

                _ := XMoveResizeWindow(info.platform_info.display,
                                       info.platform_info.window,
                                       info.platform_info.restore_x,
                                       info.platform_info.restore_y,
                                       info.platform_info.restore_width.as(u32),
                                       info.platform_info.restore_height.as(u32))
                _ := XFlush(info.platform_info.display)
                frame.width = info.platform_info.restore_width
                frame.height = info.platform_info.restore_height
            }
        }
    }

    -- Converts an X11 keysym to the common frame scan-code enum.
    frame_linux_scan_code_from_keysym :: fn (keysym: XKeySym) -> FrameScanCode {
        return on keysym {
            X_KEYSYM_BACKSPACE      => FrameScanCode.Backspace
            X_KEYSYM_TAB            => FrameScanCode.Tab
            X_KEYSYM_ENTER          => FrameScanCode.Enter
            X_KEYSYM_ESCAPE         => FrameScanCode.Escape
            X_KEYSYM_DELETE         => FrameScanCode.Delete
            X_KEYSYM_INSERT         => FrameScanCode.Insert
            X_KEYSYM_HOME           => FrameScanCode.Home
            X_KEYSYM_END            => FrameScanCode.End
            X_KEYSYM_PAGE_UP        => FrameScanCode.PageUp
            X_KEYSYM_PAGE_DOWN      => FrameScanCode.PageDown
            X_KEYSYM_ARROW_UP       => FrameScanCode.ArrowUp
            X_KEYSYM_ARROW_DOWN     => FrameScanCode.ArrowDown
            X_KEYSYM_ARROW_LEFT     => FrameScanCode.ArrowLeft
            X_KEYSYM_ARROW_RIGHT    => FrameScanCode.ArrowRight
            X_KEYSYM_SHIFT_LEFT     => FrameScanCode.LeftShift
            X_KEYSYM_SHIFT_RIGHT    => FrameScanCode.RightShift
            X_KEYSYM_CONTROL_LEFT   => FrameScanCode.LeftControl
            X_KEYSYM_CONTROL_RIGHT  => FrameScanCode.RightControl
            X_KEYSYM_ALT_LEFT       => FrameScanCode.LeftAlt
            X_KEYSYM_ALT_RIGHT      => FrameScanCode.RightAlt
            X_KEYSYM_F1             => FrameScanCode.F1
            X_KEYSYM_F2             => FrameScanCode.F2
            X_KEYSYM_F3             => FrameScanCode.F3
            X_KEYSYM_F4             => FrameScanCode.F4
            X_KEYSYM_F5             => FrameScanCode.F5
            X_KEYSYM_F6             => FrameScanCode.F6
            X_KEYSYM_F7             => FrameScanCode.F7
            X_KEYSYM_F8             => FrameScanCode.F8
            X_KEYSYM_F9             => FrameScanCode.F9
            X_KEYSYM_F10            => FrameScanCode.F10
            X_KEYSYM_F11            => FrameScanCode.F11
            X_KEYSYM_F12            => FrameScanCode.F12
            else => on (keysym >= '0'.as(XKeySym) && keysym <= '9'.as(XKeySym)) => keysym.as(u32).as(FrameScanCode)
                else on (keysym >= 'A'.as(XKeySym) && keysym <= 'Z'.as(XKeySym)) => keysym.as(u32).as(FrameScanCode)
                else on (keysym >= 'a'.as(XKeySym) && keysym <= 'z'.as(XKeySym)) => (keysym.as(u32) - 32).as(FrameScanCode)
                else FrameScanCode.Unknown
        }
    }

    -- Updates system-level modifier state from a key transition.
    frame_linux_update_modifier_state :: fn (system    : ^FrameSystem,
                                             scan_code : FrameScanCode,
                                             is_down   : bool) {
        on scan_code {
            LeftShift     => system.left_shift_down = is_down
            RightShift    => system.right_shift_down = is_down
            LeftControl   => system.left_control_down = is_down
            RightControl  => system.right_control_down = is_down
            LeftAlt       => system.left_alt_down = is_down
            RightAlt      => system.right_alt_down = is_down
        }
    }

    -- Decodes the first UTF-8 codepoint from Xlib text translation output.
    frame_linux_decode_utf8 :: fn (bytes: []u8) -> u32 {
        return utf8.decode_first_byte_slice(bytes)
    }

    -- Queues key and character events from an X11 key event.
    frame_linux_push_key_event :: fn (system  : ^FrameSystem,
                                      info    : ^FrameInfo,
                                      event   : ^XKeyEvent,
                                      is_down : bool) {
        keysym := XLookupKeysym(event, 0)
        scan_code := frame_linux_scan_code_from_keysym(keysym)
        frame_linux_update_modifier_state(system, scan_code, is_down)

        on is_down {
            yes => info.events.push(FrameEvent.KeyPress {
                scan_code
            })
            no => info.events.push(FrameEvent.KeyRelease {
                scan_code
            })
        }

        on !is_down => return

        buffer            : [8]u8
        translated_keysym : XKeySym

        count := XLookupString(event,
                               buffer[..].data.as(^i8),
                               buffer.count.as(i32),
                               ^translated_keysym,
                               nil)
        on count <= 0 => return

        codepoint := frame_linux_decode_utf8(buffer[0..count.as(usize)])
        on codepoint != 0 => {
            info.events.push(FrameEvent.Character {
                codepoint
            })
        }
    }

    -- Creates and maps a new X11 window for a public frame.
    frame_linux_create :: fn (system: ^FrameSystem, frame: ^Frame) {
        on !frame_system_has_id_capacity(system) => {
            frame.id = CLOSED_FRAME
            return
        }

        display := XOpenDisplay(nil)
        on display == nil => {
            frame.id = CLOSED_FRAME
            return
        }

        id := frame_system_allocate_id(system)
        on id == CLOSED_FRAME => {
            _ := XCloseDisplay(display)
            frame.id = CLOSED_FRAME
            return
        }

        screen := XDefaultScreen(display)
        root := XRootWindow(display, screen)
        black := XBlackPixel(display, screen)

        window := XCreateSimpleWindow(display,
                                      root,
                                      0,
                                      0,
                                      frame.width.as(u32),
                                      frame.height.as(u32),
                                      1,
                                      black,
                                      black)
        on window == 0 => {
            _ := XCloseDisplay(display)
            frame.id = CLOSED_FRAME
            return
        }

        mark := temp_arena.mark()
        defer temp_arena.restore(mark)

        _ := XStoreName(display, window, frame_c_string_temp(frame.title))
        event_mask := (X_STRUCTURE_NOTIFY_MASK | X_EXPOSURE_MASK | X_KEY_PRESS_MASK | X_KEY_RELEASE_MASK).as(XLong)
        _ := XSelectInput(display, window, event_mask)
        wm_delete := XInternAtom(display,
                                 frame_c_string_temp("WM_DELETE_WINDOW"),
                                 0)
        wm_state := XInternAtom(display,
                                frame_c_string_temp("_NET_WM_STATE"),
                                0)
        wm_state_fullscreen := XInternAtom(display,
                                           frame_c_string_temp("_NET_WM_STATE_F"
            +"ULLSCREEN"),
                                           0)
        frame_extents := XInternAtom(display,
                                     frame_c_string_temp("_NET_FRAME_EXTENTS"),
                                     0)
        _ := XSetWMProtocols(display, window, ^wm_delete, 1)
        _ := XMapWindow(display, window)

        platform_info : PlatformFrameInfo
        platform_info.display = display
        platform_info.window = window
        platform_info.wm_delete_window = wm_delete
        platform_info.wm_state = wm_state
        platform_info.wm_state_fullscreen = wm_state_fullscreen
        platform_info.frame_extents = frame_extents
        platform_info.width = frame.width
        platform_info.height = frame.height
        platform_info.restore_width = frame.width
        platform_info.restore_height = frame.height
        platform_info.full_screen = no
        platform_info.resizable = frame.resizable

        info := FrameInfo {
            id
            events: nil
            platform_info
        }
        system.frames.push(info)
        frame.id = id
        frame_linux_apply_resize_hints(frame_system_find_info(system, id),
                                       frame)
        frame_linux_apply_fullscreen(frame_system_find_info(system, id), frame)
        _ := XSync(display, X_FALSE)
    }

    -- Applies desired frame data to an existing X11 window.
    frame_linux_update_existing :: fn (system: ^FrameSystem, frame: ^Frame) {
        info := frame_system_find_info(system, frame.id)
        on info == nil => {
            frame.id = CLOSED_FRAME
            return
        }

        mark := temp_arena.mark()
        defer temp_arena.restore(mark)

        _ := XStoreName(info.platform_info.display,
                        info.platform_info.window,
                        frame_c_string_temp(frame.title))
        frame_linux_apply_resize_hints(info, frame)
        frame_linux_apply_fullscreen(info, frame)
        on !info.platform_info.full_screen => {
            _ := XResizeWindow(info.platform_info.display,
                               info.platform_info.window,
                               frame.width.as(u32),
                               frame.height.as(u32))
            frame_linux_remember_normal_geometry(info,
                                                 info.platform_info.x,
                                                 info.platform_info.y,
                                                 frame.width,
                                                 frame.height)
        }
        _ := XFlush(info.platform_info.display)
    }

    -- Copies current X11 geometry into the public frame snapshot.
    frame_linux_update_snapshot :: fn (_system : ^FrameSystem,
                                       frame   : ^Frame,
                                       info    : ^FrameInfo) {
        on info.platform_info.window == 0 => return

        root         : XWindow
        x            : i32
        y            : i32
        width        : u32
        height       : u32
        border_width : u32
        depth        : u32

        ok := XGetGeometry(info.platform_info.display,
                           info.platform_info.window,
                           ^root,
                           ^x,
                           ^y,
                           ^width,
                           ^height,
                           ^border_width,
                           ^depth)
        on ok == 0 => {
            frame.id = CLOSED_FRAME
            frame_linux_destroy_info(info)
            return
        }

        frame.width = width.as(u16)
        frame.height = height.as(u16)
        frame.full_screen = info.platform_info.full_screen
        frame.resizable = info.platform_info.resizable
        frame_linux_capture_geometry(info, x, y, width.as(u16), height.as(u16))
    }

    -- Converts one native X11 event into queued frame events.
    frame_linux_handle_event :: fn (system : ^FrameSystem,
                                    info   : ^FrameInfo,
                                    event  : ^XEvent) {
        on event.type {
            X_EVENT_KEY_PRESS => {
                key := event.as(usize).as(^XKeyEvent)
                frame_linux_push_key_event(system, info, key, yes)
            }
            X_EVENT_KEY_RELEASE => {
                key := event.as(usize).as(^XKeyEvent)
                frame_linux_push_key_event(system, info, key, no)
            }
            X_EVENT_CONFIGURE_NOTIFY => {
                configure := event.as(usize).as(^XConfigureEvent)
                width := configure.width.as(u16)
                height := configure.height.as(u16)
                on width == 0 || height == 0 => return
                frame_linux_capture_geometry(info,
                                             configure.x,
                                             configure.y,
                                             width,
                                             height)
                frame_linux_push_resize(info, width, height)
            }
            X_EVENT_CLIENT_MESSAGE => {
                client := event.as(usize).as(^XClientMessageEvent)
                on client.data0.as(XAtom) == info.platform_info.wm_delete_window => {
                    info.events.push(FrameEvent.Closed)
                }
            }
            X_EVENT_DESTROY_NOTIFY => {
                info.events.push(FrameEvent.Closed)
                info.platform_info.window = 0
            }
        }
    }

    frame_apply_impl :: fn (system: ^FrameSystem, frame: ^Frame) {
        on frame.id == CLOSED_FRAME => return

        on frame.id == NEW_FRAME => {
            frame_linux_create(system, frame)
            return
        }

        frame_linux_update_existing(system, frame)
    }

    frame_loop_impl :: fn (system: ^FrameSystem) -> bool {
        i : usize = 0
        for i < system.frames.count {
            info := ^system.frames[i]
            for info.platform_info.display != nil && XPending(info.platform_info.display) > 0 {
                event : XEvent
                _ := XNextEvent(info.platform_info.display, ^event)
                frame_linux_handle_event(system, info, ^event)
            }

            on info.id == CLOSED_FRAME => {
                system.frames.swap_delete(i)
                again
            }

            i += 1
        }

        return system.frames.count > 0
    }

    frame_update_impl :: fn (system: ^FrameSystem, frame: ^Frame) {
        on frame.id == CLOSED_FRAME => return

        info := frame_system_find_info(system, frame.id)
        on info == nil => {
            frame.id = CLOSED_FRAME
            return
        }

        frame_linux_update_snapshot(system, frame, info)
    }

    frame_poll_impl :: fn (system: ^FrameSystem, frame: ^Frame) -> FrameEvent {
        on frame.id == CLOSED_FRAME => return FrameEvent.None

        info := frame_system_find_info(system, frame.id)
        on info == nil => {
            frame.id = CLOSED_FRAME
            return FrameEvent.Closed
        }

        on info.events.count == 0 => return FrameEvent.None

        event := info.events[0]
        info.events.delete(0)
        on event == FrameEvent.Closed => frame_linux_mark_closed(system, frame)
        return event
    }

    frame_destroy_impl :: fn (system: ^FrameSystem, frame: ^Frame) {
        on frame.id == CLOSED_FRAME => return

        index := frame_system_find_info_index(system, frame.id)
        on index < system.frames.count => {
            frame_linux_destroy_info(^system.frames[index])
            system.frames.swap_delete(index)
        }
        frame.id = CLOSED_FRAME
    }

    frame_present_rects_impl :: fn (system : ^FrameSystem,
                                    frame  : ^Frame,
                                    rects  : []FramePixelRect) {
        on frame.id == CLOSED_FRAME || rects.count == 0 => return

        info := frame_system_find_info(system, frame.id)
        on info == nil ||
            info.platform_info.display == nil ||
            info.platform_info.window == 0 => return

        gc := XCreateGC(info.platform_info.display,
                        info.platform_info.window,
                        0,
                        nil)
        on gc == nil => return
        defer XFreeGC(info.platform_info.display, gc)

        for rect in rects {
            on rect.width == 0 || rect.height == 0 => again

            colour := (rect.colour & 0x00ffffff).as(XULong)
            _ := XSetForeground(info.platform_info.display, gc, colour)
            _ := XFillRectangle(info.platform_info.display,
                                info.platform_info.window,
                                gc,
                                rect.x.as(i32),
                                rect.y.as(i32),
                                rect.width.as(u32),
                                rect.height.as(u32))
        }

        _ := XFlush(info.platform_info.display)
    }

    -- Creates the GLX context exposed through `FrameContext`.
    frame_linux_gl_init :: fn (info: ^FrameInfo) -> bool {
        on info.platform_info.gl_context != nil => return yes
        on info.platform_info.display == nil ||
            info.platform_info.window == 0 => return no

        screen := XDefaultScreen(info.platform_info.display)
        depth := XDefaultDepth(info.platform_info.display, screen)
        visual_info : XVisualInfo
        matched := XMatchVisualInfo(info.platform_info.display,
                                    screen,
                                    depth,
                                    X_VISUAL_CLASS_TRUE_COLOR,
                                    ^visual_info)
        on matched == 0 => return no

        context := glXCreateContext(info.platform_info.display,
                                    ^visual_info,
                                    nil,
                                    1)
        on context == nil => return no

        made_current := glXMakeCurrent(info.platform_info.display,
                                       info.platform_info.window.as(GLXDrawable),
                                       context)
        on made_current == 0 => {
            glXDestroyContext(info.platform_info.display, context)
            return no
        }

        info.platform_info.gl_context = context
        return yes
    }

    frame_opengl_init_impl :: fn (system: ^FrameSystem, frame: ^Frame) -> bool {
        info := frame_system_find_info(system, frame.id)
        on info == nil => return no
        return frame_linux_gl_init(info)
    }

    frame_opengl_done_impl :: fn (system: ^FrameSystem, frame: ^Frame) {
        info := frame_system_find_info(system, frame.id)
        on info == nil => return
        frame_linux_gl_done(info)
    }

    frame_opengl_make_current_impl :: fn (system : ^FrameSystem,
                                          frame  : ^Frame) -> bool {
        info := frame_system_find_info(system, frame.id)
        on info == nil => return no
        on !frame_linux_gl_init(info) => return no
        made_current := glXMakeCurrent(info.platform_info.display,
                                       info.platform_info.window.as(GLXDrawable),
                                       info.platform_info.gl_context)
        return made_current != 0
    }

    frame_opengl_swap_buffers_impl :: fn (system: ^FrameSystem, frame: ^Frame) {
        info := frame_system_find_info(system, frame.id)
        on info == nil ||
            info.platform_info.display == nil ||
            info.platform_info.window == 0 => return
        glXSwapBuffers(info.platform_info.display,
                       info.platform_info.window.as(GLXDrawable))
    }

    -- Presents a packed pixel buffer through XImage when accelerated
    -- presentation is unavailable.
    frame_linux_present_pixels_ximage :: fn (info   : ^FrameInfo,
                                             buffer : FramePixelBuffer) {
        gc := XCreateGC(info.platform_info.display,
                        info.platform_info.window,
                        0,
                        nil)
        on gc == nil => return
        defer XFreeGC(info.platform_info.display, gc)

        screen := XDefaultScreen(info.platform_info.display)
        visual := XDefaultVisual(info.platform_info.display, screen)
        depth := XDefaultDepth(info.platform_info.display, screen)
        image := XCreateImage(info.platform_info.display,
                              visual,
                              depth.as(u32),
                              X_IMAGE_FORMAT_Z_PIXMAP,
                              0,
                              buffer.pixels.data.as(^i8),
                              buffer.width.as(u32),
                              buffer.height.as(u32),
                              32,
                              (buffer.stride.as(i32) * 4))
        on image == nil => return

        _ := XPutImage(info.platform_info.display,
                       info.platform_info.window,
                       gc,
                       image,
                       0,
                       0,
                       buffer.x.as(i32),
                       buffer.y.as(i32),
                       buffer.width.as(u32),
                       buffer.height.as(u32))
        image.data = nil
        _ := XDestroyImage(image)
        _ := XFlush(info.platform_info.display)
    }

    frame_present_pixels_impl :: fn (system : ^FrameSystem,
                                     frame  : ^Frame,
                                     buffer : FramePixelBuffer) {
        on frame.id == CLOSED_FRAME ||
            buffer.width == 0 ||
            buffer.height == 0 ||
            buffer.stride == 0 ||
            buffer.pixels.count == 0 => return

        info := frame_system_find_info(system, frame.id)
        on info == nil ||
            info.platform_info.display == nil ||
            info.platform_info.window == 0 => return

        required_pixels := buffer.stride.as(usize) * buffer.height.as(usize)
        on buffer.pixels.count < required_pixels => return

        frame_linux_present_pixels_ximage(info, buffer)
    }

    frame_present_scaled_pixels_impl :: fn (system : ^FrameSystem,
                                            frame  : ^Frame,
                                            buffer : FrameScaledPixelBuffer) {
        on frame.id == CLOSED_FRAME ||
            buffer.width == 0 ||
            buffer.height == 0 ||
            buffer.stride == 0 ||
            buffer.draw_width == 0 ||
            buffer.draw_height == 0 ||
            buffer.pixels.count == 0 => return

        info := frame_system_find_info(system, frame.id)
        on info == nil ||
            info.platform_info.display == nil ||
            info.platform_info.window == 0 => return

        required_pixels := buffer.stride.as(usize) * buffer.height.as(usize)
        on buffer.pixels.count < required_pixels => return

        frame_width := frame.width.as(u32)
        frame_height := frame.height.as(u32)
        pixels := temp_arena.alloc_array[u32]((frame_width * frame_height).as(usize))
        for i: usize = 0; i < pixels.count; i += 1 {
            pixels[i] = 0x00000000
        }

        for y: u32 = 0; y < buffer.height.as(u32); y += 1 {
            for x: u32 = 0; x < buffer.width.as(u32); x += 1 {
                colour := buffer.pixels[(y * buffer.stride.as(u32) + x).as(usize)] & 0x00ffffff
                dest_x := buffer.x.as(u32) + (x * buffer.draw_width.as(u32)) / buffer.width.as(u32)
                dest_y := buffer.y.as(u32) + (y * buffer.draw_height.as(u32)) / buffer.height.as(u32)
                next_x := buffer.x.as(u32) + ((x + 1) * buffer.draw_width.as(u32)) / buffer.width.as(u32)
                next_y := buffer.y.as(u32) + ((y + 1) * buffer.draw_height.as(u32)) / buffer.height.as(u32)
                for py := dest_y; py < next_y && py < frame_height; py += 1 {
                    row := (py * frame_width).as(usize)
                    for px := dest_x; px < next_x && px < frame_width; px += 1 {
                        pixels[row + px.as(usize)] = colour
                    }
                }
            }
        }

        frame_linux_present_pixels_ximage(info, FramePixelBuffer {
            x      : 0
            y      : 0
            width  : frame.width
            height : frame.height
            stride : frame.width
            pixels
        })
    }

}
