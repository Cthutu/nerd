pub Stack :: plex [T] {
    data [..]T
}

impl Stack[T] {
    pub push :: fn (self: ^Stack[T], elem: T) {
        self.data.push(elem)
    }

    pub pop :: fn (self: ^Stack[T]) -> T {
        return self.data.pop()
    }
}
