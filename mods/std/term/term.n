TermInputEvent :: enum {
    None
    KeyPress(KeyCode)
    KeyPressModified(KeyCode, u32)
    KeyDown(KeyCode)
    KeyUp(KeyCode)
    MouseMove(i32, i32)
    MouseDown(i32, i32, u32)
    MouseUp(i32, i32, u32)
    MouseWheel(i32, i32, i32, i32)
}

pub Colour :: u32

pub TERM_DEFAULT_INK        :: 0xdcdcdc.as(Colour)
pub TERM_DEFAULT_PAPER      :: 0x000000.as(Colour)
pub COLOUR_TRANSPARENT      :: 0xffffffff.as(Colour)
pub TERM_DEFAULT_MIN_WIDTH  :: 80
pub TERM_DEFAULT_MIN_HEIGHT :: 25
pub TERM_KEY_CODE_COUNT     :: 303
pub TERM_MOUSE_LEFT         :: 0x01
pub TERM_MOUSE_RIGHT        :: 0x02
pub TERM_MOUSE_MIDDLE       :: 0x04
pub TERM_MOUSE_X1           :: 0x08
pub TERM_MOUSE_X2           :: 0x10
pub TERM_MOD_SHIFT          :: 0x01
pub TERM_MOD_ALT            :: 0x02
pub TERM_MOD_CONTROL        :: 0x04

pub TermKeyboard :: plex {
    down     [TERM_KEY_CODE_COUNT]bool
    pressed  [TERM_KEY_CODE_COUNT]bool
    released [TERM_KEY_CODE_COUNT]bool
}

pub TermMouse :: plex {
    x        i32
    y        i32
    buttons  u32
    pressed  u32
    released u32
    wheel_x  i32
    wheel_y  i32
}

pub TermSimulate :: plex {
    dt        Duration
    width     u32
    height    u32
    keyboard  TermKeyboard
    mouse     TermMouse
    user_data ^void
}

pub TermPresent :: plex {
    dt        Duration
    width     u32
    height    u32
    user_data ^void
}

pub TermInput :: plex {
    width     u32
    height    u32
    keyboard  TermKeyboard
    mouse     TermMouse
    user_data ^void
}

pub TermTooSmallPolicy :: enum {
    PauseSimulation
    ContinueSimulation
}

pub TermInputFn    :: fn (TermInput)
pub TermSimulateFn :: fn (TermSimulate)
pub TermPresentFn  :: fn (TermPresent)

pub BoxStyle :: enum {
    Single
    Double
    Rounded
    Heavy
    Custom(string)
}

TermCell :: plex {
    ch    u32
    ink   Colour
    paper Colour
    flags u32
}

TermOutput :: plex {
    bytes     []u8
    count     usize
    truncated bool
}

PreparedRect :: plex {
    ok       bool
    rect     RectI32
    x_offset i32
    y_offset i32
}

CELL_DIRTY     :: 1
CELL_WIDE_HEAD :: 2
CELL_WIDE_TAIL :: 4

TERM_MAX_FRAMEBUFFER_CELLS :: 1000000

term_initialised        : bool
term_done_requested     : bool
term_last_columns       : u32
term_last_rows          : u32
term_min_width          : u32
term_min_height         : u32
term_too_small_policy   : TermTooSmallPolicy
term_present_ready      : bool
term_arena              : arena
term_arena_ready        : bool
term_fb_cells           : [..]TermCell
term_fb_width           : u32
term_fb_height          : u32
term_fb_view            : RectI32
term_fb_ready           : bool
term_present_cursor_set : bool
term_present_cursor_x   : u32
term_present_cursor_y   : u32
term_present_cursor_on  : bool
term_keyboard_down      : [TERM_KEY_CODE_COUNT]bool
term_keyboard_pressed   : [TERM_KEY_CODE_COUNT]bool
term_keyboard_released  : [TERM_KEY_CODE_COUNT]bool
term_keyboard_pulse     : [TERM_KEY_CODE_COUNT]bool
term_mouse              : TermMouse
term_input_hook         : TermInputFn
term_input_hook_set     : bool
term_input_user_data    : ^void
term_simulate_hook      : TermSimulateFn
