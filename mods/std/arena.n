pub Arena :: plex {
    base     ^void
    capacity usize
    cursor   usize
}

ffi "c" malloc (size: usize) -> ^void
ffi "c" realloc (ptr: ^void, size: usize) -> ^void
ffi "c" free (ptr: ^void)

pub arena_new :: fn (capacity: usize) -> Arena {
    return Arena {
        base: malloc(capacity)
        capacity: capacity
        cursor: 0
    }
}

pub arena_free :: fn (arena: ^Arena) {
    free(arena.base)
    arena.base = nil
    arena.capacity = 0
    arena.cursor = 0
}
