--
-- Provides Windows WGL bindings. Higher-level OpenGL commands and command
-- loading live in `std.opengl`.

use kernel
use user

ffi "opengl32" {
    pub wglCreateContext  (hdc: HDC) -> HGLRC
    pub wglMakeCurrent    (hdc: HDC, hglrc: HGLRC) -> BOOL
    pub wglDeleteContext  (hglrc: HGLRC) -> BOOL
    pub wglGetProcAddress (name: ^i8) -> ^void
}
