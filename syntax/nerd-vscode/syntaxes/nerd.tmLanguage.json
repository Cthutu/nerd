{
    "scopeName": "source.nerd",
    "name": "Nerd",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#bindings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#symbols"
        },
        {
            "include": "#punctuation"
        }
    ],
    "repository": {
        "bindings": {
            "patterns": [
                {
                    "name": "meta.binding.nerd",
                    "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(\\s*)(::)",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.nerd"
                        },
                        "3": {
                            "name": "keyword.operator.binding.nerd"
                        }
                    }
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-dash.nerd",
                    "match": "--.*$"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.function.nerd",
                    "match": "\\b(fn|return)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.nerd",
                    "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|isize|usize|string)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.integer.decimal.nerd",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.nerd",
                    "match": "\"(?:\\\\.|[^\"\\\\])*\""
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.nerd",
                    "match": "=>|->"
                },
                {
                    "name": "keyword.operator.arithmetic.nerd",
                    "match": "[+\\-*/%]"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.section.group.begin.nerd",
                    "match": "\\("
                },
                {
                    "name": "punctuation.section.group.end.nerd",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.section.block.begin.nerd",
                    "match": "\\{"
                },
                {
                    "name": "punctuation.section.block.end.nerd",
                    "match": "\\}"
                }
            ]
        },
        "symbols": {
            "patterns": [
                {
                    "name": "variable.other.readwrite.nerd",
                    "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                }
            ]
        }
    }
}
